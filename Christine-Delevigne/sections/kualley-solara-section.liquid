{% comment %}
  Section : hero (kualley-home-hero-paste) + bloc Solara complet (snippet kualley-kp-complete-block : galerie, prix Shopify, BOGO).
  Schéma : name ≤ 25 car. ; min_height 48–100 step 4 default 88.
{% endcomment %}

{% if section.settings.show_hero %}
  {% render 'kualley-home-hero-paste',
    kh_uid: section.id,
    kh_kicker: section.settings.kicker,
    kh_heading: section.settings.heading,
    kh_subheading: section.settings.subheading,
    kh_image: section.settings.image,
    kh_image_url: '',
    kh_primary_label: section.settings.primary_label,
    kh_primary_link: section.settings.primary_link,
    kh_secondary_label: section.settings.secondary_label,
    kh_secondary_link: section.settings.secondary_link,
    kh_show_scroll: section.settings.show_scroll,
    kh_scroll_label: section.settings.scroll_label,
    kh_min_height: section.settings.min_height | plus: 0,
    kh_padding_top: section.settings.padding_top,
    kh_padding_bottom: section.settings.padding_bottom,
    kh_color_scheme: section.settings.color_scheme
  %}
{% endif %}

<div class="kualley-solara-landing" id="shop-drop">
  {% if section.settings.product != blank %}
    {% render 'kualley-kp-complete-block', kp_product: section.settings.product %}
  {% else %}
    {% render 'kualley-kp-complete-block' %}
  {% endif %}
</div>

{% schema %}
{
  "name": "Kualley Solara hero",
  "settings": [
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "checkbox",
      "id": "show_hero",
      "label": "Afficher le hero",
      "default": true
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Surtitre",
      "default": "Kualley · Solara Set"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Solara — string neck elegance"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Sous-titre",
      "default": "2-piece bikini · wire free · low waist. Scroll for the full drop & BOGO."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image hero"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Bouton principal",
      "default": "Shop Solara"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Lien bouton principal",
      "info": "Vide = scroll vers le bloc produit (#shop-drop)"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Bouton secondaire",
      "default": "All swimwear"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Lien bouton secondaire"
    },
    {
      "type": "checkbox",
      "id": "show_scroll",
      "label": "Afficher l’invite à défiler",
      "default": true
    },
    {
      "type": "text",
      "id": "scroll_label",
      "label": "Texte scroll",
      "default": "Scroll"
    },
    {
      "type": "range",
      "id": "min_height",
      "min": 48,
      "max": 100,
      "step": 4,
      "label": "Hauteur minimum hero (vh)",
      "info": "Même pas que les marges (4). Avec min 50 et pas 4, 88 est refusé ; min 48 permet 48, 52, …, 88, 92, …",
      "default": 88
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Marge haute hero",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Marge basse hero",
      "default": 40
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Jeu de couleurs (hero)",
      "options": [
        { "value": "accent-1", "label": "Accent 1" },
        { "value": "accent-2", "label": "Accent 2" },
        { "value": "background-1", "label": "Fond 1" },
        { "value": "background-2", "label": "Fond 2" },
        { "value": "inverse", "label": "Inverse" }
      ],
      "default": "background-1"
    },
    {
      "type": "header",
      "content": "Bloc produit (Solara)"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Produit (optionnel)",
      "info": "Vide sur la page produit = produit courant. Renseignez sur une autre page pour forcer Solara."
    }
  ]
}
{% endschema %}
