<div class="container section">
  <div class="customer-register">
    <div class="customer-register__wrapper">
      <header class="customer-register__header text-center mb-lg">
        <h1 class="h2">{{ 'customer.register.title' | t }}</h1>
        <p>{{ 'customer.register.description' | t }}</p>
      </header>

      <div class="customer-register__form-wrapper">
        {%- form 'create_customer' -%}
          {%- if form.errors -%}
            <div class="form-errors mb-md">
              <h3>{{ 'customer.register.form_errors' | t }}</h3>
              {{ form.errors | default_errors }}
            </div>
          {%- endif -%}

          <div class="customer-register__form">
            <div class="form-row grid grid--2-col">
              <div class="form-field">
                <label for="register-first-name" class="form-label">
                  {{ 'customer.register.first_name' | t }}
                </label>
                <input type="text" 
                       name="customer[first_name]" 
                       id="register-first-name"
                       class="form-input"
                       value="{{ form.first_name }}"
                       autocomplete="given-name"
                       required>
              </div>

              <div class="form-field">
                <label for="register-last-name" class="form-label">
                  {{ 'customer.register.last_name' | t }}
                </label>
                <input type="text" 
                       name="customer[last_name]" 
                       id="register-last-name"
                       class="form-input"
                       value="{{ form.last_name }}"
                       autocomplete="family-name"
                       required>
              </div>
            </div>

            <div class="form-field">
              <label for="register-email" class="form-label">
                {{ 'customer.register.email' | t }}
              </label>
              <input type="email" 
                     name="customer[email]" 
                     id="register-email"
                     class="form-input"
                     value="{{ form.email }}"
                     autocomplete="email"
                     required>
            </div>

            <div class="form-field">
              <label for="register-password" class="form-label">
                {{ 'customer.register.password' | t }}
              </label>
              <input type="password" 
                     name="customer[password]" 
                     id="register-password"
                     class="form-input"
                     autocomplete="new-password"
                     required>
              <small class="form-help">
                {{ 'customer.register.password_requirements' | t }}
              </small>
            </div>

            <div class="form-actions">
              <button type="submit" class="button button--large">
                {{ 'customer.register.submit' | t }}
              </button>
            </div>
          </div>
        {%- endform -%}

        <div class="customer-register__login-link text-center mt-lg">
          <p>
            {{ 'customer.register.already_have_account' | t }}
            <a href="{{ routes.account_login_url }}" class="text-link">
              {{ 'customer.register.sign_in' | t }}
            </a>
          </p>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .customer-register__wrapper {
    max-width: 50rem;
    margin: 0 auto;
  }

  .customer-register__form {
    padding: var(--spacing-lg);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-lg);
    background-color: var(--color-background);
  }

  .form-row {
    gap: var(--spacing-md);
  }

  .form-help {
    display: block;
    margin-top: var(--spacing-xs);
    color: var(--color-text-light);
    font-size: 1.4rem;
  }

  .form-errors {
    padding: var(--spacing-md);
    background-color: rgba(244, 67, 54, 0.1);
    border: 1px solid var(--color-error);
    border-radius: var(--border-radius);
    color: var(--color-error);
  }

  .form-errors h3 {
    margin-bottom: var(--spacing-sm);
    font-size: 1.6rem;
  }

  .form-errors ul {
    margin: 0;
    padding-left: var(--spacing-md);
  }

  @media (max-width: 768px) {
    .form-row {
      grid-template-columns: 1fr;
    }
    
    .customer-register__form {
      padding: var(--spacing-md);
    }
  }
</style>

{% schema %}
{
  "name": "Customer Register",
  "class": "shopify-section--main-customers-register",
  "tag": "section"
}
{% endschema %} 