<div class="container section">
  <div class="gift-card text-center">
    <div class="gift-card__image-wrapper mb-lg">
      {%- assign image = section.settings.image | default: gift_card.product.featured_media -%}
      {%- if image != blank -%}
        {{ image | image_url: width: 300 | image_tag: loading: 'lazy', class: 'gift-card__image' }}
      {%- else -%}
        <div class="gift-card__placeholder">
          <svg width="120" height="80" viewBox="0 0 120 80" fill="none">
            <rect width="120" height="80" rx="8" fill="var(--color-border)"/>
            <text x="60" y="45" text-anchor="middle" fill="var(--color-text)" font-size="12">Gift Card</text>
          </svg>
        </div>
      {%- endif -%}
      
      <h1 class="h2">{{ 'gift_card.general.title' | t }}</h1>
      
      {%- if gift_card.expired or gift_card.enabled == false -%}
        <div class="gift-card__error">
          <p class="text-error">{{ 'gift_card.issued.expired' | t }}</p>
        </div>
      {%- endif -%}
    </div>

    <div class="gift-card__info">
      <div class="gift-card__balance mb-lg">
        <p class="text-small mb-sm">{{ 'gift_card.issued.remaining_amount' | t }}</p>
        
        {% if settings.currency_code_enabled %}
          {%- assign gift_card_balance = gift_card.balance | money_with_currency -%}
          {%- assign gift_card_initial_value = gift_card.initial_value | money_with_currency -%}
        {% else %}
          {%- assign gift_card_balance = gift_card.balance | money -%}
          {%- assign gift_card_initial_value = gift_card.initial_value | money -%}
        {% endif %}

        <p class="gift-card__amount h1">{{ gift_card_balance }}</p>
        
        {%- if gift_card.balance != gift_card.initial_value -%}
          <p class="text-small text-light">{{ 'gift_card.issued.out_of_html' | t: initial_value: gift_card_initial_value }}</p>
        {%- endif -%}
      </div>

      <div class="gift-card__code mb-lg">
        <p class="text-small mb-sm">{{ 'gift_card.issued.redeem_instructions' | t }}</p>
        
        <div class="gift-card__code-wrapper">
          <input type="text" 
                 value="{{ gift_card.code | format_code }}" 
                 readonly 
                 class="gift-card__code-input"
                 onclick="this.select()"
                 aria-label="{{ 'gift_card.issued.code' | t }}">
          
          <button type="button" 
                  class="button button--small" 
                  onclick="navigator.clipboard.writeText('{{ gift_card.code | escape }}')">
            {{ 'gift_card.general.copy' | t }}
          </button>
        </div>
        
        {%- if gift_card.expires_on -%}
          {%- assign expires_on = gift_card.expires_on | date: format: 'date' -%}
          <p class="text-small text-light mt-sm">{{ 'gift_card.issued.expires_on' | t: expires_on: expires_on }}</p>
        {%- endif -%}
      </div>

      <div class="gift-card__actions">
        <button type="button" class="button button--secondary" onclick="window.print()">
          {{ 'gift_card.general.print' | t }}
        </button>
        <a href="{{ routes.root_url }}" class="button">
          {{ 'gift_card.general.back_to_store' | t }}
        </a>
      </div>
    </div>
  </div>
</div>

<style>
  .gift-card {
    max-width: 50rem;
    margin: 0 auto;
    padding: var(--spacing-xl) 0;
  }

  .gift-card__image {
    max-width: 30rem;
    height: auto;
    border-radius: var(--border-radius-lg);
  }

  .gift-card__placeholder {
    display: inline-block;
    margin-bottom: var(--spacing-md);
  }

  .gift-card__amount {
    color: var(--color-accent);
    font-weight: var(--font-weight-bold);
  }

  .gift-card__code-wrapper {
    display: flex;
    gap: var(--spacing-sm);
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
  }

  .gift-card__code-input {
    padding: var(--spacing-sm);
    border: 2px solid var(--color-border);
    border-radius: var(--border-radius);
    font-family: monospace;
    font-size: 1.6rem;
    text-align: center;
    background-color: var(--color-background);
    cursor: pointer;
  }

  .gift-card__actions {
    display: flex;
    gap: var(--spacing-sm);
    justify-content: center;
    flex-wrap: wrap;
  }

  .text-error {
    color: var(--color-error);
  }

  @media print {
    .gift-card__actions {
      display: none;
    }
  }
</style>

{% schema %}
{
  "name": "Gift card",
  "class": "shopify-section--main-gift-card",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Gift card image",
      "info": "Defaults to gift card product image if not set"
    }
  ]
}
{% endschema %} 