<div class="container section">
  <div class="customer-order">
    <header class="customer-order__header mb-lg">
      <div>
        <h1 class="h2">{{ 'customer.order.title' | t: name: order.name }}</h1>
        <p class="text-light">
          {{ 'customer.order.date_html' | t: date: order.created_at | date: format: 'date' }}
        </p>
      </div>
      <a href="{{ routes.account_url }}" class="button button--secondary">
        {{ 'customer.order.back_to_account' | t }}
      </a>
    </header>

    <div class="customer-order__content grid grid--2-col">
      <!-- Order Items -->
      <div class="order-items">
        <h2 class="h4 mb-md">{{ 'customer.order.items' | t }}</h2>
        
        <div class="order-items__list">
          {%- for line_item in order.line_items -%}
            <div class="order-item">
              <div class="order-item__image">
                {%- if line_item.image -%}
                  {{ line_item.image | image_url: width: 100 | image_tag: loading: 'lazy' }}
                {%- else -%}
                  <div class="order-item__placeholder"></div>
                {%- endif -%}
              </div>
              
              <div class="order-item__details">
                <h3 class="order-item__title">
                  <a href="{{ line_item.product.url }}">{{ line_item.product.title }}</a>
                </h3>
                
                {%- if line_item.variant.title != 'Default Title' -%}
                  <p class="order-item__variant">{{ line_item.variant.title }}</p>
                {%- endif -%}
                
                <p class="order-item__quantity">
                  {{ 'customer.order.quantity' | t: quantity: line_item.quantity }}
                </p>
              </div>
              
              <div class="order-item__price">
                <span class="order-item__total">{{ line_item.final_line_price | money }}</span>
                {%- if line_item.original_line_price != line_item.final_line_price -%}
                  <span class="order-item__original">{{ line_item.original_line_price | money }}</span>
                {%- endif -%}
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>

      <!-- Order Summary -->
      <div class="order-summary">
        <h2 class="h4 mb-md">{{ 'customer.order.summary' | t }}</h2>
        
        <div class="order-summary__content">
          <div class="order-summary__totals">
            <div class="order-total-line">
              <span>{{ 'customer.order.subtotal' | t }}</span>
              <span>{{ order.line_items_subtotal_price | money }}</span>
            </div>
            
            {%- for discount in order.discounts -%}
              <div class="order-total-line order-total-line--discount">
                <span>{{ discount.title }}</span>
                <span>-{{ discount.amount | money }}</span>
              </div>
            {%- endfor -%}
            
            {%- for shipping_method in order.shipping_methods -%}
              <div class="order-total-line">
                <span>{{ shipping_method.title }}</span>
                <span>{{ shipping_method.price | money }}</span>
              </div>
            {%- endfor -%}
            
            {%- for tax_line in order.tax_lines -%}
              <div class="order-total-line">
                <span>{{ tax_line.title }} ({{ tax_line.rate_percentage }}%)</span>
                <span>{{ tax_line.price | money }}</span>
              </div>
            {%- endfor -%}
            
            <div class="order-total-line order-total-line--total">
              <span>{{ 'customer.order.total' | t }}</span>
              <span>{{ order.total_price | money }}</span>
            </div>
          </div>

          <!-- Order Status -->
          <div class="order-status mt-lg">
            <h3 class="h5 mb-sm">{{ 'customer.order.status' | t }}</h3>
            <div class="status-badges">
              <span class="status-badge status-badge--{{ order.financial_status }}">
                {{ order.financial_status_label }}
              </span>
              <span class="status-badge status-badge--{{ order.fulfillment_status }}">
                {{ order.fulfillment_status_label | default: 'Unfulfilled' }}
              </span>
            </div>
          </div>

          <!-- Addresses -->
          <div class="order-addresses mt-lg">
            <div class="address-group">
              <h3 class="h5 mb-sm">{{ 'customer.order.billing_address' | t }}</h3>
              <div class="address">
                {{ order.billing_address | format_address }}
              </div>
            </div>
            
            {%- if order.shipping_address -%}
              <div class="address-group mt-md">
                <h3 class="h5 mb-sm">{{ 'customer.order.shipping_address' | t }}</h3>
                <div class="address">
                  {{ order.shipping_address | format_address }}
                </div>
              </div>
            {%- endif -%}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .customer-order__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: var(--spacing-md);
  }

  .order-items__list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .order-item {
    display: flex;
    gap: var(--spacing-md);
    padding: var(--spacing-md);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    background-color: var(--color-background);
  }

  .order-item__image {
    flex-shrink: 0;
    width: 8rem;
    height: 8rem;
  }

  .order-item__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--border-radius);
  }

  .order-item__placeholder {
    width: 100%;
    height: 100%;
    background-color: var(--color-border);
    border-radius: var(--border-radius);
  }

  .order-item__details {
    flex: 1;
  }

  .order-item__title {
    font-weight: var(--font-weight-bold);
    margin-bottom: var(--spacing-xs);
  }

  .order-item__title a {
    text-decoration: none;
  }

  .order-item__variant,
  .order-item__quantity {
    color: var(--color-text-light);
    font-size: 1.4rem;
    margin-bottom: var(--spacing-xs);
  }

  .order-item__price {
    text-align: right;
    flex-shrink: 0;
  }

  .order-item__total {
    font-weight: var(--font-weight-bold);
  }

  .order-item__original {
    display: block;
    text-decoration: line-through;
    color: var(--color-text-light);
    font-size: 1.4rem;
  }

  .order-summary__content {
    padding: var(--spacing-lg);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    background-color: var(--color-background);
  }

  .order-total-line {
    display: flex;
    justify-content: space-between;
    margin-bottom: var(--spacing-sm);
  }

  .order-total-line--discount {
    color: var(--color-success);
  }

  .order-total-line--total {
    font-weight: var(--font-weight-bold);
    font-size: 1.8rem;
    padding-top: var(--spacing-sm);
    border-top: 1px solid var(--color-border);
    margin-top: var(--spacing-sm);
  }

  .status-badges {
    display: flex;
    gap: var(--spacing-sm);
    flex-wrap: wrap;
  }

  .status-badge {
    padding: 0.4rem 0.8rem;
    border-radius: var(--border-radius);
    font-size: 1.2rem;
    text-transform: uppercase;
    font-weight: var(--font-weight-bold);
  }

  .status-badge--paid,
  .status-badge--fulfilled {
    background-color: var(--color-success);
    color: white;
  }

  .status-badge--pending,
  .status-badge--partial {
    background-color: var(--color-warning);
    color: white;
  }

  .status-badge--refunded,
  .status-badge--cancelled {
    background-color: var(--color-error);
    color: white;
  }

  .address {
    line-height: 1.4;
  }

  @media (max-width: 768px) {
    .customer-order__content {
      grid-template-columns: 1fr;
    }
    
    .customer-order__header {
      flex-direction: column;
      text-align: center;
    }
    
    .order-item {
      flex-direction: column;
      text-align: center;
    }
    
    .order-item__image {
      align-self: center;
    }
    
    .order-item__price {
      text-align: center;
    }
  }
</style>

{% schema %}
{
  "name": "Customer Order",
  "class": "shopify-section--main-customers-order",
  "tag": "section"
}
{% endschema %} 