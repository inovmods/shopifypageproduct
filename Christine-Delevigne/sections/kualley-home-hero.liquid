{% comment %}
  Hero accueil : tout le HTML/CSS est dans snippets/kualley-home-hero-paste.liquid
  (réutilisable en « Liquid personnalisé » avec {% render 'kualley-home-hero-paste' %} — sans schema).
{% endcomment %}

{% render 'kualley-home-hero-paste',
  kh_uid: section.id,
  kh_kicker: section.settings.kicker,
  kh_heading: section.settings.heading,
  kh_subheading: section.settings.subheading,
  kh_image: section.settings.image,
  kh_image_url: '',
  kh_primary_label: section.settings.primary_label,
  kh_primary_link: section.settings.primary_link,
  kh_secondary_label: section.settings.secondary_label,
  kh_secondary_link: section.settings.secondary_link,
  kh_show_scroll: section.settings.show_scroll,
  kh_scroll_label: section.settings.scroll_label,
  kh_min_height: section.settings.min_height | plus: 0,
  kh_padding_top: section.settings.padding_top,
  kh_padding_bottom: section.settings.padding_bottom,
  kh_color_scheme: section.settings.color_scheme
%}

{% schema %}
{
  "name": "Kualley — Hero accueil",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Surtitre",
      "default": "Resort swimwear · Easter"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre (chaque mot s’anime)",
      "default": "Summer moves with you"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Sous-titre",
      "default": "Petites séries, finitions main, silhouettes pensées pour le soleil — puis découvre l’offre en dessous."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image hero (optionnel)"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Bouton principal",
      "default": "Voir le drop"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Lien bouton principal",
      "info": "Vide = ancre #shop-drop (bloc produit)"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Bouton secondaire",
      "default": "Toute la collection"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Lien bouton secondaire"
    },
    {
      "type": "checkbox",
      "id": "show_scroll",
      "label": "Afficher l’invite à défiler",
      "default": true
    },
    {
      "type": "text",
      "id": "scroll_label",
      "label": "Texte sous le trait",
      "default": "Défiler"
    },
    {
      "type": "select",
      "id": "min_height",
      "label": "Hauteur minimum (vh)",
      "options": [
        { "value": "50", "label": "50" },
        { "value": "55", "label": "55" },
        { "value": "60", "label": "60" },
        { "value": "65", "label": "65" },
        { "value": "70", "label": "70" },
        { "value": "75", "label": "75" },
        { "value": "80", "label": "80" },
        { "value": "85", "label": "85" },
        { "value": "88", "label": "88" },
        { "value": "90", "label": "90" },
        { "value": "95", "label": "95" },
        { "value": "100", "label": "100" }
      ],
      "default": "88"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Marge haute",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Marge basse",
      "default": 40
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Jeu de couleurs",
      "options": [
        { "value": "accent-1", "label": "Accent 1" },
        { "value": "accent-2", "label": "Accent 2" },
        { "value": "background-1", "label": "Fond 1" },
        { "value": "background-2", "label": "Fond 2" },
        { "value": "inverse", "label": "Inverse" }
      ],
      "default": "background-1"
    }
  ]
}
{% endschema %}
