<div class="container section">
  <div class="not-found text-center">
    <h1 class="h2 mb-md">{{ '404.general.title' | t }}</h1>
    <p class="text-large mb-lg">{{ '404.general.subtext' | t }}</p>
    <a href="{{ routes.all_products_collection_url }}" class="button button--large">
      {{ '404.general.continue_shopping' | t }}
    </a>
  </div>
</div>

<style>
  .not-found {
    padding: var(--spacing-xxl) 0;
    min-height: 50vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
</style>

{% schema %}
{
  "name": "404 Page",
  "class": "shopify-section--main-not-found",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "404 Page Settings"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Page not found"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "The page you were looking for does not exist."
    }
  ]
}
{% endschema %} 