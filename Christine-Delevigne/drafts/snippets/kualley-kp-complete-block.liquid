<!-- KUALLEY_KP_MARK_Solara_Set no-internal-header -->
{% comment %} data-k-prefer-variant-fallback uniquement si kp_prefer_static_variants — sinon le catalogue Shopify pilote le picker (taille × modèle). {% endcomment %}
<div class="kp" data-kp-root data-k-cart-sections=""{% if _kp_prefer_fb %} data-k-prefer-variant-fallback{% endif %}>
  <style>
    @font-face{font-family:'KTitle';src:url('{{ font_title }}') format('truetype');font-weight:400;font-style:normal;font-display:swap;}
    @font-face{font-family:'KBody';src:url('{{ font_body }}') format('truetype');font-weight:400;font-style:normal;font-display:swap;}
    .kp{
      --iv:#F8F5EF;--sd:#EDE4D6;--st:#C9BAA5;--wr:#A08B70;
      --dp:#1C1914;--ch:#3A3530;--mu:#7D7268;--bd:#E2D9CC;
      --wh:#FFFFFF;--cr:#FAF8F4;--gd:#C9A96E;--ok:#5A8A6A;
      --r:20px;--tr:.32s cubic-bezier(.25,.46,.45,.94);--top:0px;
      --header-safe:var(--header-group-height,var(--header-height,60px));
      font-family:'KBody',system-ui,sans-serif;color:var(--dp);background:var(--iv);
      -webkit-font-smoothing:antialiased;position:relative;
    }
    .kp *,.kp *::before,.kp *::after{box-sizing:border-box}
    .kp img,.kp video{display:block;max-width:100%}
    .kp .k-container{max-width:1280px;margin:0 auto;padding:0 16px}
    @media(min-width:1024px){.kp .k-container{padding:0 48px}}

    .kp .k-hero{background:var(--cr);padding:14px 0 56px}
    .kp .k-grid{display:block}
    @media(min-width:1024px){.kp .k-grid{display:grid;grid-template-columns:1.05fr .95fr;gap:56px;align-items:start}}

    .kp .k-gal{margin-top:6px}
    @media(min-width:1024px){.kp .k-gal{position:sticky;top:calc(var(--header-safe) + 18px)}}
    .kp .k-main{position:relative;border-radius:var(--r);overflow:hidden;background:var(--sd);aspect-ratio:3/4;box-shadow:0 18px 55px rgba(28,25,20,.12)}
    .kp .k-badge{position:absolute;top:14px;left:14px;z-index:4;background:rgba(28,25,20,.92);color:var(--gd);font-size:10px;letter-spacing:.14em;text-transform:uppercase;font-weight:900;padding:7px 12px;border-radius:999px;border:1px solid rgba(248,245,239,.12)}
    .kp .k-slide{position:absolute;inset:0;opacity:0;transform:scale(1.01);transition:opacity .45s ease,transform .65s ease}
    .kp .k-slide.on{opacity:1;transform:scale(1)}
    .kp .k-slide img,.kp .k-slide video{width:100%;height:100%;object-fit:cover}
    .kp .k-thumbs{display:flex;gap:10px;margin-top:12px;overflow-x:auto;scrollbar-width:none;padding-bottom:2px}
    .kp .k-thumbs::-webkit-scrollbar{display:none}
    .kp .k-thumb{flex-shrink:0;width:74px;height:92px;border-radius:14px;overflow:hidden;border:2px solid transparent;background:var(--sd);cursor:pointer;transition:transform var(--tr),border-color var(--tr);position:relative}
    .kp .k-thumb:hover{transform:translateY(-2px)}
    .kp .k-thumb.on{border-color:var(--dp)}
    .kp .k-thumb img{width:100%;height:100%;object-fit:cover}
    .kp .k-tag{position:absolute;left:8px;bottom:8px;font-size:10px;letter-spacing:.12em;text-transform:uppercase;font-weight:900;color:var(--iv);background:rgba(28,25,20,.78);border:1px solid rgba(248,245,239,.14);padding:4px 7px;border-radius:999px}

    .kp .k-eye{font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--wr);font-weight:900;margin:14px 0 8px}
    .kp .k-rating{margin:0 0 14px}
    .kp .k-rating__row{display:flex;align-items:center;flex-wrap:wrap;gap:8px 10px}
    .kp .k-rating__stars{color:var(--gd);font-size:14px;letter-spacing:1px;line-height:1;flex-shrink:0}
    .kp .k-rating__score{font-size:14px;font-weight:900;color:var(--dp);letter-spacing:.02em}
    .kp .k-rating__sep{color:var(--st);font-weight:700;opacity:.85}
    .kp .k-rating__proof{font-size:13px;font-weight:800;color:var(--ch);letter-spacing:.01em}
    .kp .k-rating__hint{margin:6px 0 0;font-size:11px;color:var(--mu);line-height:1.45;max-width:42ch}
    .kp .k-title{font-family:'KTitle',Georgia,serif;font-size:clamp(28px,4.6vw,46px);line-height:1.06;margin:0 0 10px}
    .kp .k-sub{color:var(--mu);font-size:14px;line-height:1.75;margin:0 0 18px;max-width:58ch}
    .kp .k-pill{display:inline-flex;align-items:center;gap:10px;padding:10px 14px;border-radius:999px;background:rgba(28,25,20,.92);color:var(--gd);border:1px solid rgba(248,245,239,.12);font-size:11px;letter-spacing:.14em;text-transform:uppercase;font-weight:900;margin:0 0 12px}

    .kp .k-price{display:flex;align-items:baseline;gap:12px;flex-wrap:wrap;margin:10px 0 6px}
    .kp .k-now{font-family:'KTitle',Georgia,serif;font-size:34px;letter-spacing:.02em}
    .kp .k-was{font-size:16px;color:var(--st);text-decoration:line-through}
    .kp .k-save{font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--ok);font-weight:900}
    .kp .k-micro{font-size:12px;color:var(--mu);margin:0 0 16px;line-height:1.6}

    .kp .k-ship{display:flex;flex-wrap:wrap;gap:10px;margin:12px 0 18px}
    .kp .k-ship i{font-style:normal;color:var(--ok);font-weight:900}
    .kp .k-chip{display:flex;align-items:center;gap:8px;font-size:12px;color:var(--ch);background:rgba(255,255,255,.55);border:1px solid rgba(28,25,20,.06);padding:8px 10px;border-radius:999px}

    .kp .k-paywrap{display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;margin:10px 0 18px}
    .kp .k-pay{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
    .kp .k-pay img{height:22px;width:auto;opacity:.85;object-fit:contain}
    .kp .k-shiplogo{display:flex;align-items:center;gap:10px}
    .kp .k-shiplogo img{height:22px;width:auto;opacity:.80}

    .kp .k-qty{display:flex;align-items:center;justify-content:space-between;gap:12px;margin:12px 0 14px}
    .kp .k-ql{font-size:12px;color:var(--mu);letter-spacing:.12em;text-transform:uppercase;font-weight:900}
    .kp .k-qc{display:flex;align-items:center;gap:8px;background:var(--wh);border:1px solid var(--bd);border-radius:999px;padding:6px}
    .kp .k-qb{width:34px;height:34px;border:none;border-radius:999px;background:rgba(28,25,20,.06);color:var(--dp);cursor:pointer;font-weight:900;transition:all var(--tr)}
    .kp .k-qb:hover{background:rgba(28,25,20,.12)}
    .kp .k-qv{min-width:34px;text-align:center;font-variant-numeric:tabular-nums;font-weight:900;color:var(--dp)}

    .kp .k-pick{border:1px solid var(--bd);border-radius:18px;background:rgba(255,255,255,.65);padding:14px;margin:14px 0}
    .kp .k-ph{display:flex;align-items:center;justify-content:space-between;gap:10px;margin-bottom:12px}
    .kp .k-pt{font-size:12px;letter-spacing:.14em;text-transform:uppercase;font-weight:900;margin:0}
    .kp .k-pr{font-size:11px;letter-spacing:.12em;text-transform:uppercase;font-weight:900;color:var(--gd);background:rgba(28,25,20,.92);border:1px solid rgba(248,245,239,.12);padding:6px 10px;border-radius:999px;white-space:nowrap}

    .kp .k-sum{display:flex;align-items:center;gap:10px;background:rgba(255,255,255,.55);border:1px solid rgba(28,25,20,.06);padding:10px 12px;border-radius:16px;margin-bottom:10px}
    .kp .k-sum__img{width:46px;height:58px;border-radius:12px;overflow:hidden;background:var(--sd);flex-shrink:0}
    .kp .k-sum__img img{width:100%;height:100%;object-fit:cover}
    .kp .k-sum__txt{min-width:0}
    .kp .k-sum__name{font-weight:900;font-size:13px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .kp .k-sum__var{font-size:12px;color:var(--mu);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}

    .kp .k-ol{font-size:11px;letter-spacing:.12em;text-transform:uppercase;font-weight:900;color:var(--mu);margin:10px 0 8px}
    .kp .k-or{display:flex;flex-wrap:wrap;gap:8px}
    .kp .k-ob{border:1.5px solid var(--bd);background:var(--wh);color:var(--ch);padding:11px 12px;border-radius:14px;cursor:pointer;font-size:13px;font-weight:900;transition:all var(--tr);user-select:none}
    .kp .k-ob:hover{border-color:var(--dp);transform:translateY(-1px)}
    .kp .k-ob.on{background:var(--dp);border-color:var(--dp);color:var(--iv)}
    .kp .k-ob.off{opacity:.35;cursor:not-allowed;transform:none}

    .kp .k-btn{width:100%;display:flex;align-items:center;justify-content:center;gap:10px;padding:16px 18px;border:none;border-radius:16px;cursor:pointer;font-size:13px;font-weight:900;letter-spacing:.14em;text-transform:uppercase;transition:all var(--tr);font-family:'KBody',system-ui,sans-serif}
    .kp .k-btn.primary{background:var(--dp);color:var(--iv);box-shadow:0 16px 40px rgba(28,25,20,.18)}
    .kp .k-btn.primary:hover{transform:translateY(-1px);background:var(--ch)}
    .kp .k-btn.primary:disabled{opacity:.55;cursor:not-allowed;transform:none}
    .kp [data-k-add].kp-atc--busy{opacity:.55;pointer-events:none;cursor:wait}
    .kp .k-linkbtn{background:none;border:none;cursor:pointer;font-size:12px;color:var(--wr);font-weight:900;letter-spacing:.1em;text-transform:uppercase;text-decoration:underline;text-underline-offset:3px;padding:0}
    .kp .k-atc-wrap{margin-top:18px;margin-bottom:0}
    .shopify-section .kp [data-k-add],.shopify-block .kp [data-k-add]{display:flex!important;visibility:visible!important;opacity:1!important;max-height:none!important;clip:auto!important}

    .kp .k-sticky{position:fixed;left:0;right:0;bottom:0;z-index:9995;background:rgba(248,245,239,.97);backdrop-filter:saturate(1.2) blur(12px);-webkit-backdrop-filter:saturate(1.2) blur(12px);border-top:1px solid var(--bd);padding:6px 0 calc(8px + env(safe-area-inset-bottom,0px));transform:translate3d(0,110%,0);transition:transform .32s var(--tr);visibility:hidden;pointer-events:none}
    .kp .k-sticky.k-sticky--on{transform:translate3d(0,0,0);visibility:visible;pointer-events:auto}
    .kp.kp--sticky-bar{padding-bottom:calc(76px + env(safe-area-inset-bottom,0px))}
    @media(min-width:900px){.kp.kp--sticky-bar{padding-bottom:calc(72px + env(safe-area-inset-bottom,0px))}}
    .kp .k-sticky__inner{max-width:1280px;margin:0 auto;padding:0 12px}
    @media(min-width:1024px){.kp .k-sticky__inner{padding:0 48px}}
    .kp .k-sticky__bar{display:flex;align-items:center;gap:8px}
    .kp .k-sticky__hit{flex:1;min-width:0;display:flex;align-items:center;gap:10px;padding:6px 10px;border-radius:14px;border:1px solid var(--bd);background:rgba(255,255,255,.72);cursor:pointer;font:inherit;color:inherit;-webkit-tap-highlight-color:transparent;text-align:left;transition:border-color var(--tr),background var(--tr)}
    .kp .k-sticky__hit:active{background:rgba(255,255,255,.92)}
    .kp .k-sticky__thumb{width:40px;height:50px;border-radius:10px;object-fit:cover;flex-shrink:0;background:var(--sd);display:block}
    .kp .k-sticky__meta{flex:1;min-width:0;display:flex;flex-direction:column;gap:1px}
    .kp .k-sticky__eyebrow{font-size:8px;letter-spacing:.14em;text-transform:uppercase;font-weight:900;color:var(--mu);line-height:1.2}
    .kp .k-sticky__sel{font-size:11px;font-weight:900;color:var(--dp);line-height:1.25;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .kp .k-sticky__chev{flex-shrink:0;width:22px;height:22px;border-radius:999px;border:1px solid var(--bd);display:flex;align-items:center;justify-content:center;font-size:9px;color:var(--mu)}
    .kp .k-sticky__cta--bar{flex-shrink:0;width:auto!important;min-width:92px;max-width:110px;padding:12px 10px!important;font-size:10px!important;letter-spacing:.1em!important;white-space:nowrap}
    .kp .k-sticky-sheet{position:fixed;inset:0;z-index:9998;pointer-events:none}
    .kp .k-sticky-sheet.k-sticky-sheet--on{pointer-events:auto}
    .kp .k-sticky-sheet__backdrop{position:absolute;inset:0;background:rgba(28,25,20,.5);opacity:0;transition:opacity .28s ease}
    .kp .k-sticky-sheet.k-sticky-sheet--on .k-sticky-sheet__backdrop{opacity:1}
    .kp .k-sticky-sheet__panel{position:absolute;left:0;right:0;bottom:0;max-height:min(82dvh,560px);background:var(--wh);border-radius:20px 20px 0 0;box-shadow:0 -12px 40px rgba(28,25,20,.15);transform:translate3d(0,105%,0);transition:transform .34s cubic-bezier(.25,.46,.45,.94);display:flex;flex-direction:column}
    .kp .k-sticky-sheet.k-sticky-sheet--on .k-sticky-sheet__panel{transform:translate3d(0,0,0)}
    .kp .k-sticky-sheet__head{display:flex;align-items:center;justify-content:space-between;gap:12px;padding:14px 16px 10px;border-bottom:1px solid rgba(28,25,20,.08);flex-shrink:0}
    .kp .k-sticky-sheet__title{font-family:'KTitle',Georgia,serif;font-size:18px;margin:0;color:var(--dp)}
    .kp .k-sticky-sheet__x{width:38px;height:38px;border-radius:999px;border:1px solid var(--bd);background:rgba(28,25,20,.04);cursor:pointer;font-weight:900;font-size:16px;line-height:1;color:var(--dp)}
    .kp .k-sticky-sheet__body{padding:12px 16px calc(16px + env(safe-area-inset-bottom,0px));overflow-y:auto;-webkit-overflow-scrolling:touch;flex:1;min-height:0}
    .kp .k-sticky-sheet__slot{display:flex;align-items:flex-start;gap:8px;margin-bottom:14px}
    .kp .k-sticky-sheet__slot:last-of-type{margin-bottom:8px}
    .kp .k-sticky-sheet__tag{flex-shrink:0;font-size:10px;letter-spacing:.14em;text-transform:uppercase;font-weight:900;color:var(--mu);padding-top:6px}
    .kp .k-sticky-sheet__slot [data-k-picker-sticky]{flex:1;min-width:0}
    .kp .k-sticky-sheet [data-k-picker-sticky] .k-ol{font-size:10px;margin:0 0 8px;letter-spacing:.1em}
    .kp .k-sticky-sheet [data-k-picker-sticky] .k-or{gap:8px}
    .kp .k-sticky-sheet [data-k-picker-sticky] .k-ob{padding:10px 12px;font-size:12px;border-radius:12px}
    .kp .k-sticky-sheet__atc{margin-top:6px;padding-top:4px}
    .kp .k-sticky-sheet__atc [data-k-add]{width:100%}

    .kp .k-acc{margin-top:18px;border-top:1px solid var(--bd)}
    .kp .k-ai{border-bottom:1px solid var(--bd)}
    .kp .k-ab{width:100%;padding:18px 0;background:none;border:none;display:flex;justify-content:space-between;align-items:center;gap:14px;cursor:pointer;text-align:left}
    .kp .k-aq{font-size:14px;font-weight:900;color:var(--dp)}
    .kp .k-ax{width:30px;height:30px;border-radius:999px;border:1.5px solid var(--bd);display:flex;align-items:center;justify-content:center;font-weight:900;transition:all var(--tr);flex-shrink:0}
    .kp .k-ap{max-height:0;overflow:hidden;transition:max-height .42s ease}
    .kp .k-at{padding:0 0 18px;color:var(--mu);font-size:14px;line-height:1.8}
    .kp .k-ai.on .k-ap{max-height:900px}
    .kp .k-ai.on .k-ax{background:var(--dp);color:var(--iv);border-color:var(--dp);transform:rotate(45deg)}
    .kp .k-spec{list-style:none;padding:0;margin:10px 0 0;display:grid;gap:10px}
    .kp .k-spec li{display:flex;justify-content:space-between;gap:12px;background:rgba(255,255,255,.55);border:1px solid rgba(28,25,20,.06);padding:10px 12px;border-radius:14px}
    .kp .k-spec b{color:var(--dp)}

    .kp .k-social-micro{margin-top:10px;margin-bottom:10px;padding-bottom:10px;border-bottom:1px solid rgba(28,25,20,.06)}
    .kp .k-social-micro__head{display:flex;align-items:center;gap:6px;margin:0 0 4px}
    .kp .k-social-micro__ig{width:12px;height:12px;opacity:.72;flex-shrink:0}
