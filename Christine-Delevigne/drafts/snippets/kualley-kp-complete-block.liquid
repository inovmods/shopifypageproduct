{% comment %}
  Kualley Solara Set — BOGO, sticky, bottom sheet. Sans barre interne (header = thème).
  ATC : même logique que snippets/kualley-kp-compact.liquid (data-k-add + fetch cart/add.js) — ex. produit Marea.
  {% render 'kualley-kp-complete-block' %} · kp_product · kp_home_handle
{% endcomment %}
{% assign kp_home_handle = kp_home_handle | default: '' %}
{% if kp_product != blank %}
  {% assign p = kp_product %}
{% elsif kp_home_handle != blank %}
  {% assign p = all_products[kp_home_handle] %}
{% else %}
  {% assign p = product %}
  {% if p == blank and closest.product != blank %}
    {% assign p = closest.product %}
  {% endif %}
  {% if p == blank %}
    {% assign p = all_products['kualley-solara-set'] %}
  {% endif %}
  {% if p == blank %}
    {% assign p = collections.all.products.first %}
  {% endif %}
{% endif %}

{% if p == blank %}
  <div class="kp kp--empty" style="padding:48px 20px;text-align:center;font-family:system-ui,sans-serif;background:#F8F5EF;color:#1C1914;">
    <p style="margin:0;max-width:420px;margin-inline:auto;line-height:1.6;">Aucun produit à afficher. Utilisez une <strong>page produit</strong>, choisissez un produit dans la section, ou passez <code>kp_home_handle</code> / <code>kp_product</code> au render.</p>
  </div>
{% else %}
{% assign base_price_cents = 7000 %}
{% assign compare_price_cents = 10000 %}
{% assign save_price_cents = compare_price_cents | minus: base_price_cents %}

{% assign r_base = base_price_cents | modulo: 100 %}
{% assign d_base = base_price_cents | divided_by: 100 %}
{% assign r_cmp = compare_price_cents | modulo: 100 %}
{% assign d_cmp = compare_price_cents | divided_by: 100 %}
{% assign r_sav = save_price_cents | modulo: 100 %}
{% assign d_sav = save_price_cents | divided_by: 100 %}

