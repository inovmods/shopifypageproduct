{%- comment -%}
  Blueprint Theme - Social Icons Snippet
  Renders social media icons based on theme settings
{%- endcomment -%}

{%- liquid
  assign social_accounts = 'Facebook,Twitter,Pinterest,Instagram,TikTok,Tumblr,Snapchat,YouTube,Vimeo' | split: ','
-%}

<ul class="list-unstyled list-social {% if class %}{{ class }}{% endif %}" role="list">
  {%- for social in social_accounts -%}
    {%- assign social_handle = social | handleize -%}
    {%- capture social_link -%}social_{{ social_handle }}_link{%- endcapture -%}
    {%- capture social_icon -%}icon-{{ social_handle }}{%- endcapture -%}
    
    {%- if settings[social_link] != blank -%}
      <li class="list-social__item">
        <a href="{{ settings[social_link] }}" class="list-social__link link">
          {%- case social_handle -%}
            {%- when 'facebook' -%}
              <svg aria-hidden="true" focusable="false" class="icon icon-facebook" viewBox="0 0 18 18">
                <path fill="currentColor" d="M16.42.61c.27 0 .5.22.5.5v15.78c0 .27-.23.5-.5.5h-4.52v-6.87h2.3l.34-2.68h-2.64V5.84c0-.77.21-1.3 1.32-1.3h1.42V1.99c-.25-.03-1.09-.11-2.07-.11-2.05 0-3.45 1.25-3.45 3.55v1.98H7.04v2.68h2.28V17.4H1.11c-.27 0-.5-.23-.5-.5V1.11c0-.28.23-.5.5-.5h15.31z"/>
              </svg>
            {%- when 'twitter' -%}
              <svg aria-hidden="true" focusable="false" class="icon icon-twitter" viewBox="0 0 18 15">
                <path fill="currentColor" d="M17.64 2.6a7.33 7.33 0 01-1.75 1.82c0 .13 0 .27 0 .41 0 4.12-3.13 8.87-8.87 8.87A8.87 8.87 0 010 11.77a6.32 6.32 0 004.66-1.3 3.12 3.12 0 01-2.91-2.16 3.12 3.12 0 001.41-.05 3.12 3.12 0 01-2.5-3.06v-.04a3.12 3.12 0 001.41.39 3.12 3.12 0 01-.97-4.15 8.84 8.84 0 006.41 3.25 3.12 3.12 0 015.32-2.84 6.23 6.23 0 001.98-.76 3.12 3.12 0 01-1.37 1.72 6.18 6.18 0 001.79-.49z"/>
              </svg>
            {%- when 'pinterest' -%}
              <svg aria-hidden="true" focusable="false" class="icon icon-pinterest" viewBox="0 0 17 18">
                <path fill="currentColor" d="M8.48.58c-4.42 0-6.66 3.17-6.66 5.82 0 1.6.61 3.03 1.91 3.56.21.08.4 0 .46-.23.04-.16.15-.61.2-.79.06-.24.04-.32-.13-.53-.38-.45-.62-1.03-.62-1.85 0-2.38 1.78-4.51 4.64-4.51 2.53 0 3.92 1.55 3.92 3.61 0 2.72-1.2 5.01-2.99 5.01-.99 0-1.73-.82-1.49-1.82.29-1.2.84-2.48.84-3.35 0-.77-.42-1.42-1.28-1.42-1.01 0-1.83.95-1.83 2.22 0 .81.28 1.36.28 1.36S3.95 9.72 3.7 10.8c-.54 2.26.08 5.02.13 5.29.03.16.23.2.32.08.13-.17 1.78-2.2 2.4-4.4.18-.63.99-3.88.99-3.88.49.94 1.93 1.76 3.46 1.76 4.55 0 7.64-4.15 7.64-9.7C18.67 4.01 14.37.58 8.48.58z"/>
              </svg>
            {%- when 'instagram' -%}
