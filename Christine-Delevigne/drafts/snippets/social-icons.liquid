            {%- when 'vimeo' -%}
              <svg aria-hidden="true" focusable="false" class="icon icon-vimeo" viewBox="0 0 18 16">
                <path fill="currentColor" d="M17.36 4.34c-.07 1.63-.12 2.72-.12 2.72s-.81 7.24-1.17 8.27c-.36 1.03-1.86 1.57-2.99 1.03-1.13-.54-6.41-5.01-7.1-5.55-.69-.54-1.74-2.07-2.07-3.1-.33-1.03.54-1.57 1.17-1.03.63.54 2.61 2.07 3.24 2.61.63.54 1.26.54 1.26-.54 0-1.08-.18-3.69-.18-4.77 0-1.08.36-2.61 1.35-2.61.99 0 1.98 1.08 2.43 1.62.45.54 1.08 1.08 1.35 1.62.27.54.54 1.08.54 1.62 0 .54.27 1.08.63 1.08.36 0 .72-.54.72-1.08 0-.54-.18-1.62-.18-2.16 0-.54.18-1.08.54-1.08.36 0 .72.54.72 1.08 0 .54.18 1.62.18 2.16 0 .54.18 1.08.54 1.08.36 0 .72-.54.72-1.08 0-.54-.18-1.62-.18-2.16z"/>
              </svg>
            {%- when 'tumblr' -%}
              <svg aria-hidden="true" focusable="false" class="icon icon-tumblr" viewBox="0 0 11 18">
                <path fill="currentColor" d="M6.13 7.5V4.5h2.25V1.13H6.13V0H3.38v1.13c0 1.87-1.51 3.37-3.38 3.37v2.25h1.13V12c0 3.31 2.69 6 6 6h2.25v-3.38H7.5c-1.24 0-2.25-1.01-2.25-2.25V6.75h2.25V7.5H6.13z"/>
              </svg>
            {%- when 'snapchat' -%}
              <svg aria-hidden="true" focusable="false" class="icon icon-snapchat" viewBox="0 0 18 17">
                <path fill="currentColor" d="M9 0C4.37 0 1.68 3.3 1.68 6.67c0 2.52 1.52 4.62 3.85 5.23.43.11.43-.18.43-.29 0-.13-.02-.56-.02-1.02-2.02.44-2.45-.97-2.45-.97-.33-.84-.81-1.07-.81-1.07-.66-.45.05-.44.05-.44.73.05 1.11.75 1.11.75.65 1.11 1.7.79 2.11.6.07-.47.25-.79.46-.97-1.61-.18-3.3-.8-3.3-3.58 0-.79.28-1.44.75-1.95-.08-.18-.32-.92.07-1.91 0 0 .61-.2 2 .74.58-.16 1.2-.24 1.82-.24.62 0 1.24.08 1.82.24 1.39-.94 2-.74 2-.74.39.99.15 1.73.07 1.91.47.51.75 1.16.75 1.95 0 2.79-1.7 3.4-3.32 3.58.26.22.49.66.49 1.33 0 .96-.01 1.73-.01 1.97 0 .19.13.42.49.35C14.82 15.13 16.32 13.03 16.32 10.5 16.32 3.3 13.63 0 9 0z"/>
              </svg>
          {%- endcase -%}
          <span class="visually-hidden">{{ 'general.social.links.' | append: social_handle | t }}</span>
        </a>
      </li>
    {%- endif -%}
  {%- endfor -%}
</ul> 