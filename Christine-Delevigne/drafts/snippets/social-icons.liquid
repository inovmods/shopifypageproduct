                <path fill="currentColor" d="M8.8 4a4.5 4.5 0 100 9 4.5 4.5 0 000-9zm0 7.43a2.92 2.92 0 110-5.85 2.92 2.92 0 010 5.85zM13.43 5a1.05 1.05 0 100-2.1 1.05 1.05 0 000 2.1z"/>
              </svg>
            {%- when 'tiktok' -%}
              <svg aria-hidden="true" focusable="false" class="icon icon-tiktok" viewBox="0 0 18 18">
                <path fill="currentColor" d="M8.02 0H11.296V2.975C11.296 4.54 12.58 5.824 14.144 5.824H15.84V9.1H12.707C12.316 9.1 12 9.416 12 9.807V18H8.725V9.807C8.725 9.416 8.409 9.1 8.018 9.1H4.885V5.824H6.581C8.145 5.824 9.429 4.54 9.429 2.975V0H8.02Z"/>
              </svg>
            {%- when 'youtube' -%}
              <svg aria-hidden="true" focusable="false" class="icon icon-youtube" viewBox="0 0 18 13">
                <path fill="currentColor" d="M15.36 2.04c-.2-.74-.78-1.32-1.53-1.53C12.64.18 9 .18 9 .18s-3.64 0-4.83.33c-.75.21-1.33.79-1.53 1.53C2.32 3.23 2.32 6.5 2.32 6.5s0 3.27.32 4.46c.2.74.78 1.32 1.53 1.53C5.36 12.82 9 12.82 9 12.82s3.64 0 4.83-.33c.75-.21 1.33-.79 1.53-1.53.32-1.19.32-4.46.32-4.46s0-3.27-.32-4.46zM7.27 9.27V3.73L11.73 6.5 7.27 9.27z"/>
