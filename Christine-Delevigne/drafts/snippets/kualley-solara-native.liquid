  <script>
  (function () {
    var root = document.getElementById('kp-solara-native-{{ p.id }}');
    if (!root) return;

    function q(sel) { return root.querySelector(sel); }
    function qa(sel) { return Array.prototype.slice.call(root.querySelectorAll(sel)); }
    function closest(el, sel) {
      if (!el) return null;
      if (el.closest) return el.closest(sel);
      while (el && el.nodeType === 1) {
        if (el.matches && el.matches(sel)) return el;
        el = el.parentNode;
      }
      return null;
    }

    function parseRoughKg(str) {
      if (!str || typeof str !== 'string') return null;
      var s = str.toLowerCase().replace(/,/g, '.');
      var m = s.match(/[\d.]+/);
      if (!m) return null;
      var n = parseFloat(m[0]);
      if (isNaN(n)) return null;
      if (s.indexOf('lb') !== -1) return n * 0.453592;
      return n;
    }

    function parseRoughCm(str) {
      if (!str || typeof str !== 'string') return null;
      var s = str.toLowerCase();
      var m;
      if (s.indexOf('cm') !== -1) {
        m = s.match(/[\d.]+/);
        return m ? parseFloat(m[0]) : null;
      }
      if (s.indexOf('ft') !== -1 || s.indexOf("'") !== -1) {
        var ft = 0, inch = 0;
        m = s.match(/(\d+)\s*ft/);
        if (m) ft = parseInt(m[1], 10);
        m = s.match(/(\d+)\s*'\s*(\d+)/);
        if (m) { ft = parseInt(m[1], 10); inch = parseInt(m[2], 10); }
        return Math.round((ft * 12 + inch) * 2.54) || null;
      }
      m = s.match(/[\d.]+/);
      return m ? parseFloat(m[0]) : null;
    }

    function suggestSolaraSize(cup, heightStr, weightStr) {
      var c = (cup || '').toUpperCase();
      var base = 'M';
      if (c === 'A' || c === 'B') base = 'S';
      else if (c === 'C') base = 'M';
      else if (c === 'D') base = 'L';
      else if (c === 'DD') base = 'XL';
      var kg = parseRoughKg(weightStr);
      var cm = parseRoughCm(heightStr);
      if (kg && kg >= 82) {
        if (base === 'S') base = 'M';
        else if (base === 'M' && kg >= 92) base = 'L';
        else if (base === 'L' && kg >= 100) base = 'XL';
      }
      if (cm && cm >= 175 && kg && kg >= 68 && base === 'S') base = 'M';
      return base;
    }

    function initSizeHelper() {
      var btn = q('[data-k-sq-submit]');
      var res = q('[data-k-sq-result]');
      if (!btn || !res || btn._kSqBound) return;
      btn._kSqBound = true;
      btn.addEventListener('click', function () {
        var cupEl = q('[data-k-sq-cup]');
        var hEl = q('[data-k-sq-height]');
        var wEl = q('[data-k-sq-weight]');
        var cup = cupEl ? cupEl.value : '';
        var hs = hEl ? String(hEl.value || '').trim() : '';
        var ws = wEl ? String(wEl.value || '').trim() : '';
        if (!cup) {
          res.textContent = 'Select your bra cup size so we can suggest a starting point.';
          res.classList.add('on');
          return;
        }
        var sz = suggestSolaraSize(cup, hs, ws);
        res.innerHTML = '<strong>Suggested starting size: ' + sz + '</strong><br>Match with the <b>Size chart</b>. Allow <b>1–3 cm</b> variance.';
        res.classList.add('on');
      });
    }

    function showSlide(i) {
      qa('[data-k-slide]').forEach(function (sl) {
        sl.classList.toggle('on', sl.getAttribute('data-k-slide') === String(i));
        var vid = sl.querySelector('video');
        if (vid) {
          try { sl.classList.contains('on') ? vid.play() : vid.pause(); } catch (e) {}
        }
      });
      qa('[data-k-thumb]').forEach(function (th) {
        th.classList.toggle('on', th.getAttribute('data-k-thumb') === String(i));
      });
    }

    function openModal() {
      var m = q('[data-k-modal]');
      if (!m) return;
      m.classList.add('on');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      var m = q('[data-k-modal]');
      if (!m) return;
      m.classList.remove('on');
      document.body.style.overflow = '';
    }

    function initReveal() {
      var els = qa('.rev');
      if (!els.length) return;
      if (!('IntersectionObserver' in window)) {
        for (var i = 0; i < els.length; i++) els[i].classList.add('on');
        return;
      }
      var obs = new IntersectionObserver(function (entries) {
        for (var j = 0; j < entries.length; j++) {
          if (entries[j].isIntersecting) {
            entries[j].target.classList.add('on');
            obs.unobserve(entries[j].target);
          }
        }
      }, { threshold: 0.12, rootMargin: '0px 0px -60px 0px' });
      for (var k = 0; k < els.length; k++) obs.observe(els[k]);
    }

    root.addEventListener('click', function (e) {
      var t = e.target;
      var th = closest(t, '[data-k-thumb]');
      if (th) {
        showSlide(th.getAttribute('data-k-thumb'));
        return;
      }
      if (closest(t, '[data-k-open-size]')) {
        openModal();
        return;
      }
      if (closest(t, '[data-k-close]')) {
        closeModal();
        return;
      }
      var modal = q('[data-k-modal]');
      if (modal && modal.classList.contains('on') && t === modal) {
        closeModal();
        return;
      }
      var tab = closest(t, '[data-k-tab]');
      if (tab && modal) {
        var key = tab.getAttribute('data-k-tab');
        qa('[data-k-tab]').forEach(function (x) { x.classList.toggle('on', x === tab); });
        qa('[data-k-pane]').forEach(function (p) {
          p.classList.toggle('on', p.getAttribute('data-k-pane') === key);
        });
        return;
      }
      var acc = closest(t, '[data-k-acc]');
      if (acc) {
        var item = closest(acc, '.k-ai');
        if (!item) return;
        var all = qa('.k-ai');
        var isOpen = item.classList.contains('on');
        for (var i = 0; i < all.length; i++) all[i].classList.remove('on');
        item.classList.toggle('on', !isOpen);
      }
    });

    document.addEventListener('keydown', function (e) {
      if (e.key !== 'Escape') return;
      closeModal();
    });

    showSlide(0);
    initReveal();
    initSizeHelper();
  })();
  </script>
</div>
{% endif %}
