{% comment %}
  Solara — même présentation que le bloc Kualley, achat via formulaire produit Shopify natif (pas de JS panier).
  Usage : {% render 'kualley-solara-native', kp_product: product %}
  Sur page produit sans argument : le produit courant est utilisé.
{% endcomment %}
{% assign kp_home_handle = kp_home_handle | default: '' %}
{% if kp_product != blank %}
  {% assign p = kp_product %}
{% elsif kp_home_handle != blank %}
  {% assign p = all_products[kp_home_handle] %}
{% else %}
  {% assign p = product %}
  {% if p == blank and closest.product != blank %}
    {% assign p = closest.product %}
  {% endif %}
{% endif %}

{% if p == blank %}
  <div class="kp kp--empty kp--solara-native" style="padding:48px 20px;text-align:center;font-family:system-ui,sans-serif;background:#F8F5EF;color:#1C1914;">
    <p style="margin:0;max-width:420px;margin-inline:auto;line-height:1.6;">Choisissez un produit (section) ou affichez ce bloc sur une <strong>page produit</strong>.</p>
  </div>
{% else %}
{% assign form_id = 'KualleySolaraNative-' | append: p.id %}
{% assign support_email = shop.email %}

{% assign ig_logo = 'https://cdn.shopify.com/s/files/1/1033/9418/1457/files/Instagram-Logo.wine.svg?v=1774735024' %}
{% assign ship_logo = 'https://cdn.shopify.com/s/files/1/1033/9418/1457/files/United_States_Postal_Service-Logo.wine.svg?v=1774735024' %}
{% assign pay_apple = 'https://cdn.shopify.com/s/files/1/1033/9418/1457/files/Apple_Pay-Logo.wine.svg?v=1774735024' %}
{% assign pay_mc = 'https://cdn.shopify.com/s/files/1/1033/9418/1457/files/Mastercard-Logo.wine.svg?v=1774735024' %}
{% assign pay_amex = 'https://cdn.shopify.com/s/files/1/1033/9418/1457/files/American_Express-Logo.wine_1.svg?v=1774735024' %}
{% assign pay_shop = 'https://cdn.shopify.com/s/files/1/1033/9418/1457/files/shoppay_logo-removebg-preview.png?v=1774735059' %}
{% assign pay_pp = 'https://cdn.shopify.com/s/files/1/1033/9418/1457/files/PayPal-Logo.wine.svg?v=1774735024' %}

{% assign video_1 = 'https://cdn.shopify.com/videos/c/o/v/ff2842c4f7e4443cb0fe4768dba8cea1.mp4' %}
{% assign font_body = 'https://cdn.shopify.com/s/files/1/1033/9418/1457/files/amoera-Regular.ttf?v=1774791198' %}
{% assign font_title = 'https://cdn.shopify.com/s/files/1/1033/9418/1457/files/Malline.ttf?v=1774787392' %}
{% assign fallback_img = p.featured_image | image_url: width: 900 %}
{% assign img_1 = 'https://cdn.shopify.com/s/files/1/1033/9418/1457/files/Generated_Image_April_06_2026_-_4_17PM.webp?v=1775677133' %}
{% assign img_2 = 'https://cdn.shopify.com/s/files/1/1033/9418/1457/files/Generated_Image_April_06_2026_-_4_10PM.webp?v=1775677133' %}
{% assign img_3 = 'https://cdn.shopify.com/s/files/1/1033/9418/1457/files/Generated_Image_April_06_2026_-_4_34PM.webp?v=1775677133' %}
{% assign img_4 = 'https://cdn.shopify.com/s/files/1/1033/9418/1457/files/Generated_Image_April_06_2026_-_4_35PM.webp?v=1775677133' %}
{% assign sol_model_1 = 'https://cdn.shopify.com/s/files/1/1033/9418/1457/files/Generated_Image_April_06_2026_-_4_00PM.webp?v=1775677099' %}
{% assign sol_model_2 = 'https://cdn.shopify.com/s/files/1/1033/9418/1457/files/Generated_Image_April_06_2026_-_3_51PM.webp?v=1775677099' %}
{% assign sol_model_3 = 'https://cdn.shopify.com/s/files/1/1033/9418/1457/files/Generated_Image_April_06_2026_-_3_57PM.webp?v=1775677099' %}
{% assign sol_model_4 = 'https://cdn.shopify.com/s/files/1/1033/9418/1457/files/Generated_Image_April_06_2026_-_3_47PM.webp?v=1775677099' %}
{% assign sol_ig_1 = 'https://cdn.shopify.com/s/files/1/1033/9418/1457/files/Generated_Image_April_06_2026_-_4_48PM.webp?v=1775677099' %}
{% assign sol_ig_2 = 'https://cdn.shopify.com/s/files/1/1033/9418/1457/files/Generated_Image_April_06_2026_-_4_51PM.webp?v=1775677099' %}
{% assign sol_ig_3 = 'https://cdn.shopify.com/s/files/1/1033/9418/1457/files/Generated_Image_April_06_2026_-_4_46PM.webp?v=1775677133' %}

<div class="kp kp--solara-native" id="kp-solara-native-{{ p.id }}">
  <style>
    @font-face{font-family:'KTitle';src:url('{{ font_title }}') format('truetype');font-weight:400;font-style:normal;font-display:swap;}
    @font-face{font-family:'KBody';src:url('{{ font_body }}') format('truetype');font-weight:400;font-style:normal;font-display:swap;}
    .kp.kp--solara-native{
      --iv:#F8F5EF;--sd:#EDE4D6;--st:#C9BAA5;--wr:#A08B70;
      --dp:#1C1914;--ch:#3A3530;--mu:#7D7268;--bd:#E2D9CC;
      --wh:#FFFFFF;--cr:#FAF8F4;--gd:#C9A96E;--ok:#5A8A6A;
      --r:20px;--tr:.32s cubic-bezier(.25,.46,.45,.94);
      --header-safe:var(--header-group-height,var(--header-height,60px));
      font-family:'KBody',system-ui,sans-serif;color:var(--dp);background:var(--iv);
      -webkit-font-smoothing:antialiased;position:relative;
    }
    .kp.kp--solara-native *,.kp.kp--solara-native *::before,.kp.kp--solara-native *::after{box-sizing:border-box}
    .kp.kp--solara-native img,.kp.kp--solara-native video{display:block;max-width:100%}
    .kp.kp--solara-native .k-container{max-width:1280px;margin:0 auto;padding:0 16px}
    @media(min-width:1024px){.kp.kp--solara-native .k-container{padding:0 48px}}
    .kp.kp--solara-native .k-hero{background:var(--cr);padding:14px 0 56px}
    .kp.kp--solara-native .k-grid{display:block}
    @media(min-width:1024px){.kp.kp--solara-native .k-grid{display:grid;grid-template-columns:1.05fr .95fr;gap:56px;align-items:start}}
    .kp.kp--solara-native .k-gal{margin-top:6px}
    @media(min-width:1024px){.kp.kp--solara-native .k-gal{position:sticky;top:calc(var(--header-safe) + 18px)}}
    .kp.kp--solara-native .k-main{position:relative;border-radius:var(--r);overflow:hidden;background:var(--sd);aspect-ratio:3/4;box-shadow:0 18px 55px rgba(28,25,20,.12)}
    .kp.kp--solara-native .k-badge{position:absolute;top:14px;left:14px;z-index:4;background:rgba(28,25,20,.92);color:var(--gd);font-size:10px;letter-spacing:.14em;text-transform:uppercase;font-weight:900;padding:7px 12px;border-radius:999px;border:1px solid rgba(248,245,239,.12)}
    .kp.kp--solara-native .k-slide{position:absolute;inset:0;opacity:0;transform:scale(1.01);transition:opacity .45s ease,transform .65s ease}
    .kp.kp--solara-native .k-slide.on{opacity:1;transform:scale(1)}
    .kp.kp--solara-native .k-slide img,.kp.kp--solara-native .k-slide video{width:100%;height:100%;object-fit:cover}
    .kp.kp--solara-native .k-thumbs{display:flex;gap:10px;margin-top:12px;overflow-x:auto;scrollbar-width:none;padding-bottom:2px}
    .kp.kp--solara-native .k-thumbs::-webkit-scrollbar{display:none}
    .kp.kp--solara-native .k-thumb{flex-shrink:0;width:74px;height:92px;border-radius:14px;overflow:hidden;border:2px solid transparent;background:var(--sd);cursor:pointer;transition:transform var(--tr),border-color var(--tr);position:relative}
    .kp.kp--solara-native .k-thumb:hover{transform:translateY(-2px)}
    .kp.kp--solara-native .k-thumb.on{border-color:var(--dp)}
    .kp.kp--solara-native .k-thumb img{width:100%;height:100%;object-fit:cover}
    .kp.kp--solara-native .k-tag{position:absolute;left:8px;bottom:8px;font-size:10px;letter-spacing:.12em;text-transform:uppercase;font-weight:900;color:var(--iv);background:rgba(28,25,20,.78);border:1px solid rgba(248,245,239,.14);padding:4px 7px;border-radius:999px}
    .kp.kp--solara-native .k-eye{font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--wr);font-weight:900;margin:14px 0 8px}
    .kp.kp--solara-native .k-rating{margin:0 0 14px}
    .kp.kp--solara-native .k-rating__row{display:flex;align-items:center;flex-wrap:wrap;gap:8px 10px}
    .kp.kp--solara-native .k-rating__stars{color:var(--gd);font-size:14px;letter-spacing:1px;line-height:1;flex-shrink:0}
    .kp.kp--solara-native .k-rating__score{font-size:14px;font-weight:900;color:var(--dp);letter-spacing:.02em}
    .kp.kp--solara-native .k-rating__sep{color:var(--st);font-weight:700;opacity:.85}
    .kp.kp--solara-native .k-rating__proof{font-size:13px;font-weight:800;color:var(--ch);letter-spacing:.01em}
    .kp.kp--solara-native .k-rating__hint{margin:6px 0 0;font-size:11px;color:var(--mu);line-height:1.45;max-width:42ch}
    .kp.kp--solara-native .k-title{font-family:'KTitle',Georgia,serif;font-size:clamp(28px,4.6vw,46px);line-height:1.06;margin:0 0 10px}
    .kp.kp--solara-native .k-sub{color:var(--mu);font-size:14px;line-height:1.75;margin:0 0 18px;max-width:58ch}
    .kp.kp--solara-native .k-pill{display:inline-flex;align-items:center;gap:10px;padding:10px 14px;border-radius:999px;background:rgba(28,25,20,.92);color:var(--gd);border:1px solid rgba(248,245,239,.12);font-size:11px;letter-spacing:.14em;text-transform:uppercase;font-weight:900;margin:0 0 12px}
    .kp.kp--solara-native .k-price{display:flex;align-items:baseline;gap:12px;flex-wrap:wrap;margin:10px 0 6px}
    .kp.kp--solara-native .k-now{font-family:'KTitle',Georgia,serif;font-size:34px;letter-spacing:.02em}
    .kp.kp--solara-native .k-was{font-size:16px;color:var(--st);text-decoration:line-through}
    .kp.kp--solara-native .k-save{font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--ok);font-weight:900}
    .kp.kp--solara-native .k-ship{display:flex;flex-wrap:wrap;gap:10px;margin:12px 0 18px}
    .kp.kp--solara-native .k-ship i{font-style:normal;color:var(--ok);font-weight:900}
    .kp.kp--solara-native .k-chip{display:flex;align-items:center;gap:8px;font-size:12px;color:var(--ch);background:rgba(255,255,255,.55);border:1px solid rgba(28,25,20,.06);padding:8px 10px;border-radius:999px}
    .kp.kp--solara-native .k-paywrap{display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;margin:10px 0 18px}
    .kp.kp--solara-native .k-pay{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
    .kp.kp--solara-native .k-pay img{height:22px;width:auto;opacity:.85;object-fit:contain}
    .kp.kp--solara-native .k-shiplogo{display:flex;align-items:center;gap:10px}
    .kp.kp--solara-native .k-shiplogo img{height:22px;width:auto;opacity:.80}
    .kp.kp--solara-native .k-linkbtn{background:none;border:none;cursor:pointer;font-size:12px;color:var(--wr);font-weight:900;letter-spacing:.1em;text-transform:uppercase;text-decoration:underline;text-underline-offset:3px;padding:0}
    .kp.kp--solara-native .k-native-form{margin-top:8px;display:grid;gap:16px}
    .kp.kp--solara-native .k-native-form label.k-ol{display:block;font-size:11px;letter-spacing:.12em;text-transform:uppercase;font-weight:900;color:var(--mu);margin:0 0 8px}
    .kp.kp--solara-native .k-native-select,.kp.kp--solara-native .k-native-qty{width:100%;padding:12px 14px;border-radius:14px;border:1.5px solid var(--bd);background:var(--wh);font-family:inherit;font-size:14px;color:var(--dp)}
    .kp.kp--solara-native .k-native-select:focus,.kp.kp--solara-native .k-native-qty:focus{outline:2px solid rgba(201,169,110,.45);outline-offset:2px}
    .kp.kp--solara-native .k-btn{width:100%;display:flex;align-items:center;justify-content:center;gap:10px;padding:16px 18px;border:none;border-radius:16px;cursor:pointer;font-size:13px;font-weight:900;letter-spacing:.14em;text-transform:uppercase;transition:all var(--tr);font-family:'KBody',system-ui,sans-serif}
    .kp.kp--solara-native .k-btn.primary{background:var(--dp);color:var(--iv);box-shadow:0 16px 40px rgba(28,25,20,.18)}
    .kp.kp--solara-native .k-btn.primary:hover{transform:translateY(-1px);background:var(--ch)}
    .kp.kp--solara-native .k-btn.primary:disabled{opacity:.55;cursor:not-allowed;transform:none}
    .kp.kp--solara-native .k-native-form .shopify-payment-button{margin-top:4px}
    .kp.kp--solara-native .k-atc-wrap{margin-top:4px;margin-bottom:0}
    .kp.kp--solara-native .k-acc{margin-top:18px;border-top:1px solid var(--bd)}
    .kp.kp--solara-native .k-ai{border-bottom:1px solid var(--bd)}
    .kp.kp--solara-native .k-ab{width:100%;padding:18px 0;background:none;border:none;display:flex;justify-content:space-between;align-items:center;gap:14px;cursor:pointer;text-align:left}
    .kp.kp--solara-native .k-aq{font-size:14px;font-weight:900;color:var(--dp)}
    .kp.kp--solara-native .k-ax{width:30px;height:30px;border-radius:999px;border:1.5px solid var(--bd);display:flex;align-items:center;justify-content:center;font-weight:900;transition:all var(--tr);flex-shrink:0}
    .kp.kp--solara-native .k-ap{max-height:0;overflow:hidden;transition:max-height .42s ease}
    .kp.kp--solara-native .k-at{padding:0 0 18px;color:var(--mu);font-size:14px;line-height:1.8}
    .kp.kp--solara-native .k-ai.on .k-ap{max-height:900px}
    .kp.kp--solara-native .k-ai.on .k-ax{background:var(--dp);color:var(--iv);border-color:var(--dp);transform:rotate(45deg)}
    .kp.kp--solara-native .k-spec{list-style:none;padding:0;margin:10px 0 0;display:grid;gap:10px}
    .kp.kp--solara-native .k-spec li{display:flex;justify-content:space-between;gap:12px;background:rgba(255,255,255,.55);border:1px solid rgba(28,25,20,.06);padding:10px 12px;border-radius:14px}
    .kp.kp--solara-native .k-spec b{color:var(--dp)}
    .kp.kp--solara-native .k-social-micro{margin-top:12px;margin-bottom:10px;padding-bottom:10px;border-bottom:1px solid rgba(28,25,20,.06)}
    .kp.kp--solara-native .k-social-micro__head{display:flex;align-items:center;gap:6px;margin:0 0 4px}
    .kp.kp--solara-native .k-social-micro__ig{width:12px;height:12px;opacity:.72;flex-shrink:0}
    .kp.kp--solara-native .k-social-micro__label{font-size:9px;letter-spacing:.16em;text-transform:uppercase;font-weight:900;color:var(--wr);margin:0}
    .kp.kp--solara-native .k-social-micro__tag{margin:0 0 8px;font-size:10px;color:var(--mu);line-height:1.4;max-width:48ch}
    .kp.kp--solara-native .k-sgrid--micro{display:flex;flex-direction:row;flex-wrap:nowrap;gap:8px;margin:0;overflow-x:auto;overflow-y:hidden;-webkit-overflow-scrolling:touch;scroll-snap-type:x mandatory;padding:2px 0 6px;scrollbar-width:thin}
    .kp.kp--solara-native .k-sgrid--micro::-webkit-scrollbar{height:5px}
    .kp.kp--solara-native .k-sgrid--micro::-webkit-scrollbar-thumb{background:rgba(28,25,20,.18);border-radius:999px}
    .kp.kp--solara-native .k-scard--micro{position:relative;flex:0 0 104px;width:104px;scroll-snap-align:start;border-radius:12px;overflow:hidden;background:var(--sd);aspect-ratio:4/5;box-shadow:0 6px 18px rgba(28,25,20,.08)}
    .kp.kp--solara-native .k-scard--micro img{width:100%;height:100%;object-fit:cover;display:block}
    .kp.kp--solara-native .k-sov--micro{position:absolute;inset:0;background:linear-gradient(to top,rgba(28,25,20,.58),transparent 52%);display:flex;align-items:flex-end;padding:6px 6px 7px}
    .kp.kp--solara-native .k-sov--micro span{color:var(--iv);font-weight:900;letter-spacing:.1em;text-transform:uppercase;font-size:8px;line-height:1.2}
    .kp.kp--solara-native .k-sec{padding:76px 0;background:var(--cr)}
    .kp.kp--solara-native .k-hd{text-align:center;margin-bottom:32px}
    .kp.kp--solara-native .k-he{display:block;font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--wr);font-weight:900;margin-bottom:10px}
    .kp.kp--solara-native .k-ht{font-family:'KTitle',Georgia,serif;font-size:clamp(24px,4vw,40px);line-height:1.1;margin:0}
    .kp.kp--solara-native .k-hs{max-width:58ch;margin:12px auto 0;color:var(--mu);font-size:15px;line-height:1.75}
    .kp.kp--solara-native .k-grid2{display:grid;gap:16px;grid-template-columns:1fr}
    @media(min-width:900px){.kp.kp--solara-native .k-grid2{grid-template-columns:1fr 1fr;gap:22px}}
    .kp.kp--solara-native .k-img{border-radius:20px;overflow:hidden;background:var(--sd);position:relative;min-height:420px;box-shadow:0 18px 55px rgba(28,25,20,.10)}
    .kp.kp--solara-native .k-img img{width:100%;height:100%;object-fit:cover}
    .kp.kp--solara-native .k-ov{position:absolute;inset:0;background:linear-gradient(to top,rgba(28,25,20,.64),transparent 55%);display:flex;align-items:flex-end;padding:16px;opacity:0;transition:opacity .35s ease}
    .kp.kp--solara-native .k-img:hover .k-ov{opacity:1}
    .kp.kp--solara-native .k-ov span{color:var(--iv);font-weight:900;letter-spacing:.10em;text-transform:uppercase;font-size:12px}
    .kp.kp--solara-native .rev{opacity:0;transform:translateY(18px);transition:opacity .7s ease,transform .7s ease}
    .kp.kp--solara-native .rev.on{opacity:1;transform:translateY(0)}
    .kp.kp--solara-native .d1{transition-delay:.08s}.kp.kp--solara-native .d2{transition-delay:.16s}.kp.kp--solara-native .d3{transition-delay:.24s}
    .kp.kp--solara-native .k-modal{position:fixed;inset:0;background:rgba(28,25,20,.62);z-index:9997;display:flex;align-items:flex-end;justify-content:center;opacity:0;pointer-events:none;transition:opacity .25s ease}
    @media(min-width:700px){.kp.kp--solara-native .k-modal{align-items:center}}
    .kp.kp--solara-native .k-modal.on{opacity:1;pointer-events:all}
    .kp.kp--solara-native .k-box{width:100%;max-width:760px;background:var(--wh);border-radius:18px 18px 0 0;padding:18px 18px 22px;transform:translateY(110%);transition:transform .35s ease;max-height:88vh;overflow:auto}
    @media(min-width:700px){.kp.kp--solara-native .k-box{border-radius:18px;transform:scale(.96)} .kp.kp--solara-native .k-modal.on .k-box{transform:scale(1)}}
    .kp.kp--solara-native .k-modal.on .k-box{transform:translateY(0)}
    .kp.kp--solara-native .k-bh{display:flex;justify-content:space-between;align-items:center;gap:12px;padding:6px 2px 12px;border-bottom:1px solid rgba(28,25,20,.08)}
    .kp.kp--solara-native .k-bt{font-family:'KTitle',Georgia,serif;font-size:22px;margin:0}
    .kp.kp--solara-native .k-x{width:36px;height:36px;border-radius:999px;border:1px solid rgba(28,25,20,.12);background:rgba(28,25,20,.04);cursor:pointer;font-weight:900}
    .kp.kp--solara-native .k-tabs{display:flex;gap:10px;margin:14px 0;flex-wrap:wrap}
    .kp.kp--solara-native .k-tab{border:1px solid rgba(28,25,20,.12);background:rgba(28,25,20,.04);padding:10px 12px;border-radius:999px;cursor:pointer;font-weight:900;font-size:12px;letter-spacing:.12em;text-transform:uppercase}
    .kp.kp--solara-native .k-tab.on{background:var(--dp);color:var(--iv);border-color:var(--dp)}
    .kp.kp--solara-native .k-pane{display:none}
    .kp.kp--solara-native .k-pane.on{display:block}
    .kp.kp--solara-native table{width:100%;border-collapse:collapse;font-size:13px;margin-top:10px;border-radius:16px;overflow:hidden;border:1px solid rgba(28,25,20,.10)}
    .kp.kp--solara-native th,.kp.kp--solara-native td{padding:10px 12px;border-bottom:1px solid rgba(28,25,20,.08);text-align:left}
    .kp.kp--solara-native th{background:var(--sd);font-size:11px;letter-spacing:.12em;text-transform:uppercase;font-weight:900}
    .kp.kp--solara-native .k-chart-wrap{overflow-x:auto;margin-top:8px;-webkit-overflow-scrolling:touch}
    .kp.kp--solara-native .k-chart-wrap table{min-width:520px;font-size:12px}
    .kp.kp--solara-native .k-sq-intro{margin:0 0 12px;color:var(--mu);font-size:13px;line-height:1.65}
    .kp.kp--solara-native .k-sq{display:grid;gap:14px;margin-top:6px}
    .kp.kp--solara-native .k-sq__field label{display:block;font-size:11px;letter-spacing:.12em;text-transform:uppercase;font-weight:900;color:var(--mu);margin-bottom:6px}
    .kp.kp--solara-native .k-sq__hint{font-weight:600;opacity:.65;text-transform:none;letter-spacing:0}
    .kp.kp--solara-native .k-sq__field input,.kp.kp--solara-native .k-sq__field select{width:100%;padding:11px 12px;border-radius:14px;border:1.5px solid var(--bd);background:var(--wh);font-family:inherit;font-size:14px;color:var(--dp)}
    .kp.kp--solara-native .k-sq__btn{margin-top:4px;width:100%}
    .kp.kp--solara-native .k-sq-result{margin-top:14px;padding:14px 16px;border-radius:16px;background:rgba(90,138,106,.1);border:1px solid rgba(90,138,106,.28);font-size:14px;line-height:1.55;color:var(--dp);display:none}
    .kp.kp--solara-native .k-sq-result.on{display:block}
