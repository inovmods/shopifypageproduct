        margin: 0 -0.25rem;
        scrollbar-width: none;
        -ms-overflow-style: none;
      }
      .cdl-pdp__story-cards::-webkit-scrollbar {
        display: none;
        height: 0;
        width: 0;
      }
      @media (min-width: 900px) {
        .cdl-pdp__story-cards {
          display: grid;
          grid-template-columns: repeat(3, 1fr);
          overflow: visible;
          margin: 0;
          scroll-snap-type: none;
        }
      }
      .cdl-pdp__story-card {
        flex: 0 0 min(82vw, 340px);
        scroll-snap-align: center;
        border-radius: 20px;
        border: 1px solid rgba(222, 210, 199, 0.8);
        background: rgba(255, 255, 255, 0.65);
        overflow: hidden;
        box-shadow: 0 16px 44px rgba(46, 35, 29, 0.07);
      }
      @media (min-width: 900px) {
        .cdl-pdp__story-card {
          flex: none;
        }
      }
      .cdl-pdp__story-card-media {
        position: relative;
        aspect-ratio: 4/5;
        overflow: hidden;
      }
      .cdl-pdp__story-card-media img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
      .cdl-pdp__story-badge {
        position: absolute;
        top: 0.65rem;
        left: 0.65rem;
        font-size: 0.58rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        font-weight: 700;
        padding: 0.3rem 0.55rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.92);
        border: 1px solid rgba(222, 210, 199, 0.85);
        color: var(--cdl-espresso);
      }
      .cdl-pdp__story-card-title {
        font-family: var(--cdl-font-display);
        font-size: 1.05rem;
        font-weight: 700;
        margin: 0.85rem 1rem 0.35rem;
        letter-spacing: -0.02em;
      }
      .cdl-pdp__story-card-text {
        margin: 0 1rem 1.1rem;
        font-size: 0.8rem;
        line-height: 1.6;
        color: var(--cdl-cocoa);
      }
      .cdl-pdp__rail-outer--framed {
        margin-top: 0;
        border-top: none;
        background: linear-gradient(180deg, rgba(248, 244, 238, 0.4), rgba(251, 248, 244, 0.95));
      }
      .cdl-pdp__rail-dek {
        max-width: 1120px;
        margin: -0.35rem auto 1.25rem;
        padding: 0 1.25rem;
        font-size: 0.84rem;
        line-height: 1.6;
        color: var(--cdl-cocoa);
        text-align: center;
      }
      @media (min-width: 1024px) {
        .cdl-pdp__rail-dek {
          padding: 0 2.5rem;
        }
      }
      .cdl-pdp__rail {
        scrollbar-width: none;
        -ms-overflow-style: none;
      }
      .cdl-pdp__rail::-webkit-scrollbar {
        display: none;
        height: 0;
        width: 0;
      }
      .cdl-pdp__acc-lead {
        font-size: 0.9rem;
        line-height: 1.65;
        color: var(--cdl-cocoa);
        margin: 0 0 0.75rem;
        font-style: italic;
      }
      .cdl-pdp__pay-row {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.65rem 1rem;
        margin-top: 0.85rem;
      }
      .cdl-pdp__pay-row img {
        height: 22px;
        width: auto;
        opacity: 0.88;
        transition: opacity 0.25s ease;
      }
      .cdl-pdp__pay-row img:hover {
        opacity: 1;
      }
      .cdl-pdp__pay-row .cdl-pdp__pay--shop {
        height: 26px;
      }
      [data-cdl-reveal] {
        opacity: 0;
        transform: translate3d(0, 32px, 0);
        transition: opacity 0.9s var(--cdl-ease), transform 0.9s var(--cdl-ease);
        will-change: opacity, transform;
      }
      [data-cdl-reveal].cdl-is-inview {
        opacity: 1;
        transform: translate3d(0, 0, 0);
      }
      [data-cdl-reveal='slide-left'] {
        transform: translate3d(48px, 0, 0);
      }
      [data-cdl-reveal='slide-left'].cdl-is-inview {
        transform: translate3d(0, 0, 0);
      }
      [data-cdl-reveal='slide-right'] {
        transform: translate3d(-48px, 0, 0);
      }
      [data-cdl-reveal='slide-right'].cdl-is-inview {
        transform: translate3d(0, 0, 0);
      }
      [data-cdl-reveal-delay='1'] {
        transition-delay: 0.08s;
      }
      [data-cdl-reveal-delay='2'] {
        transition-delay: 0.16s;
      }
      [data-cdl-reveal-delay='3'] {
        transition-delay: 0.24s;
      }
      .cdl-pdp__rail-outer {
        margin: 3rem calc(50% - 50vw) 0;
        width: 100vw;
        max-width: 100vw;
        padding: 2.25rem 0 2.5rem;
        background: linear-gradient(180deg, rgba(251, 248, 244, 0.95), rgba(243, 236, 227, 0.85));
        border-block: 1px solid var(--cdl-hairline);
      }
      .cdl-pdp__rail-head {
        max-width: 1200px;
        margin: 0 auto 1.25rem;
        padding: 0 1.25rem;
        display: flex;
        flex-wrap: wrap;
        align-items: baseline;
        justify-content: space-between;
        gap: 0.75rem;
      }
      @media (min-width: 1024px) {
        .cdl-pdp__rail-head {
          padding: 0 3rem;
        }
      }
      .cdl-pdp__rail-title {
        font-family: var(--cdl-font-display);
        font-size: clamp(1.25rem, 2.4vw, 1.65rem);
        margin: 0;
        letter-spacing: -0.02em;
      }
      .cdl-pdp__rail-hint {
        font-size: 0.75rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        font-weight: 600;
        color: var(--cdl-cocoa);
      }
      .cdl-pdp__rail {
        position: relative;
        overflow: hidden;
        mask-image: linear-gradient(90deg, transparent, #000 4%, #000 96%, transparent);
        -webkit-mask-image: linear-gradient(90deg, transparent, #000 4%, #000 96%, transparent);
      }
      .cdl-pdp__rail-track {
        display: flex;
        gap: 1rem;
        width: max-content;
        padding: 0.25rem 1.25rem 0.5rem;
        animation: cdl-marquee-x 42s linear infinite;
      }
      .cdl-pdp__rail:hover .cdl-pdp__rail-track {
        animation-play-state: paused;
      }
      @media (max-width: 1023px) {
        .cdl-pdp__rail {
          overflow-x: auto;
          overflow-y: hidden;
          scroll-snap-type: x mandatory;
          -webkit-overflow-scrolling: touch;
          mask-image: none;
          -webkit-mask-image: none;
        }
        .cdl-pdp__rail-track {
          animation: none;
          padding-inline: 1.25rem;
        }
        .cdl-pdp__rail-card {
          scroll-snap-align: center;
        }
      }
      .cdl-pdp__rail-card {
        flex: 0 0 auto;
        width: min(72vw, 300px);
        border-radius: 22px;
        overflow: hidden;
        border: 1px solid rgba(222, 210, 199, 0.75);
        box-shadow: 0 14px 40px rgba(46, 35, 29, 0.07);
        background: var(--cdl-card);
      }
      .cdl-pdp__rail-card img {
        width: 100%;
        aspect-ratio: 4/5;
        object-fit: cover;
        display: block;
        transform: scale(1.01);
        transition: transform 0.7s var(--cdl-ease);
      }
      .cdl-pdp__rail-card:hover img {
        transform: scale(1.06);
      }
      @keyframes cdl-marquee-x {
        from {
          transform: translateX(0);
        }
        to {
          transform: translateX(-50%);
        }
      }
      .cdl-pdp__details-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.9rem;
      }
      .cdl-pdp__details-table th,
      .cdl-pdp__details-table td {
        text-align: left;
        padding: 0.65rem 0;
        border-bottom: 1px solid var(--cdl-hairline);
        vertical-align: top;
      }
      .cdl-pdp__details-table th {
        font-weight: 600;
        color: var(--cdl-espresso);
        width: 38%;
      }
      .cdl-pdp__details-table td {
        color: var(--cdl-cocoa);
      }
      @keyframes cdl-fade-up {
        from {
          opacity: 0;
          transform: translateY(12px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      @media (prefers-reduced-motion: reduce) {
        .cdl-pdp__rail-track {
          animation: none;
        }
        .cdl-pdp__acc-body {
          animation: none;
        }
        [data-cdl-reveal] {
          opacity: 1;
          transform: none;
          transition: none;
        }
      }
    </style>

  {% when 'instagram' %}
    {% liquid
      assign ig_title = s.ig_heading | default: 'As Seen on Instagram'
      assign ig_logo = s.ig_logo | default: 'https://cdn.shopify.com/s/files/1/0985/0997/9992/files/Instagram-Logo.wine.svg?v=1776006309'
      assign ig_1 = ig_override_1
      if ig_1 == blank
        assign ig_1 = s.ig_image_1 | default: 'https://cdn.shopify.com/s/files/1/0985/0997/9992/files/Generated_Image_April_12_2026_-_4_51PM.jpg?v=1776005866'
      endif
      assign ig_2 = ig_override_2
      if ig_2 == blank
        assign ig_2 = s.ig_image_2 | default: 'https://cdn.shopify.com/s/files/1/0985/0997/9992/files/Generated_Image_April_12_2026_-_4_53PM.jpg?v=1776005866'
      endif
      assign ig_3 = ig_override_3
      if ig_3 == blank
        assign ig_3 = s.ig_image_3 | default: 'https://cdn.shopify.com/s/files/1/0985/0997/9992/files/Generated_Image_April_12_2026_-_4_55PM.jpg?v=1776005866'
      endif
      assign ig_url = s.instagram_url | default: 'https://www.instagram.com/'
    %}
    <div class="cdl-pdp__ig-wrap cdl-pdp__ig-wrap--atc">
      <div class="cdl-pdp__ig-head">
        <img src="{{ ig_logo }}" width="90" height="22" alt="Instagram" loading="lazy">
        <h3 class="cdl-pdp__ig-title">{{ ig_title }}</h3>
      </div>
      <div class="cdl-pdp__ig-grid">
        <a href="{{ ig_url }}" rel="noopener noreferrer" target="_blank" aria-label="Instagram 1">
          <img src="{{ ig_1 }}" alt="" loading="lazy" width="400" height="400">
        </a>
        <a href="{{ ig_url }}" rel="noopener noreferrer" target="_blank" aria-label="Instagram 2">
          <img src="{{ ig_2 }}" alt="" loading="lazy" width="400" height="400">
        </a>
        <a href="{{ ig_url }}" rel="noopener noreferrer" target="_blank" aria-label="Instagram 3">
          <img src="{{ ig_3 }}" alt="" loading="lazy" width="400" height="400">
        </a>
      </div>
    </div>

  {% when 'payments' %}
    {% liquid
      assign p1 = s.pay_mc | default: 'https://cdn.shopify.com/s/files/1/0985/0997/9992/files/Mastercard-Logo.wine.svg?v=1776006309'
      assign p2 = s.pay_amex | default: 'https://cdn.shopify.com/s/files/1/0985/0997/9992/files/American_Express-Logo.wine_1.svg?v=1776006309'
      assign p3 = s.pay_apple | default: 'https://cdn.shopify.com/s/files/1/0985/0997/9992/files/Apple_Pay-Logo.wine_1.svg?v=1776006309'
      assign p4 = s.pay_paypal | default: 'https://cdn.shopify.com/s/files/1/0985/0997/9992/files/PayPal-Logo.wine.svg?v=1776006309'
      assign p5 = s.pay_shop | default: 'https://cdn.shopify.com/s/files/1/0985/0997/9992/files/shoppay_logo-removebg-preview.png?v=1776006382'
    %}
    <div class="cdl-pdp__pay-row" aria-label="Accepted payments">
      <img src="{{ p1 }}" alt="Mastercard" height="22" loading="lazy">
      <img src="{{ p2 }}" alt="American Express" height="22" loading="lazy">
      <img src="{{ p3 }}" alt="Apple Pay" height="22" loading="lazy">
      <img src="{{ p4 }}" alt="PayPal" height="22" loading="lazy">
      <img class="cdl-pdp__pay--shop" src="{{ p5 }}" alt="Shop Pay" height="26" loading="lazy">
    </div>

  {% when 'shipping_badge' %}
    {% liquid
      assign ship_logo = s.shipping_logo | default: 'https://cdn.shopify.com/s/files/1/0985/0997/9992/files/United_States_Postal_Service-Logo.wine.svg?v=1776006309'
    %}
    <span class="cdl-pdp__micro">
      <span class="cdl-pdp__ship-mark" aria-hidden="true">
        <img src="{{ ship_logo }}" alt="" width="40" height="14" loading="lazy">
      </span>
      <span>{{ s.prep_text | default: 'Made to order in 2–3 days' }} · {{ s.ship_text | default: 'Ships in 5–7 business days' }} · {{ s.returns_text | default: '30-day returns' }}</span>
    </span>
{% endcase %}
