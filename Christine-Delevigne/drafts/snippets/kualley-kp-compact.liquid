<div class="kp" data-kp-root data-k-cart-sections=""{% if _kp_prefer_fb %} data-k-prefer-variant-fallback{% endif %}>
<style>
.kp{--iv:#F8F5EF;--sd:#EDE4D6;--st:#C9BAA5;--wr:#A08B70;--dp:#1C1914;--ch:#3A3530;--mu:#7D7268;--bd:#E2D9CC;--wh:#FFF;--cr:#FAF8F4;--gd:#C9A96E;--ok:#5A8A6A;--r:20px;--tr:.32s cubic-bezier(.25,.46,.45,.94);--top:66px;--header-safe:var(--header-group-height,var(--header-height,60px));font-family:Georgia,system-ui,serif;color:var(--dp);background:var(--iv);-webkit-font-smoothing:antialiased;position:relative}
.kp *,.kp *::before,.kp *::after{box-sizing:border-box}
.kp img,.kp video{display:block;max-width:100%}
.kp .k-container{max-width:1280px;margin:0 auto;padding:0 16px}
@media(min-width:1024px){.kp .k-container{padding:0 48px}}
.kp .k-topbar{position:sticky;top:var(--header-safe);z-index:4;background:var(--iv);border-bottom:1px solid var(--bd)}
.kp .k-topbar__inner{height:var(--top);max-width:1280px;margin:0 auto;padding:0 16px;display:flex;align-items:center;justify-content:space-between;gap:12px}
@media(min-width:1024px){.kp .k-topbar__inner{padding:0 48px}}
.kp .k-brand{display:flex;align-items:center;gap:10px;min-width:0}
.kp .k-logo{height:34px;width:auto;object-fit:contain}
.kp .k-offer{display:flex;align-items:center;gap:10px;color:var(--ch);font-size:12px;letter-spacing:.16em;text-transform:uppercase;font-weight:900;white-space:nowrap}
.kp .k-savepill{display:none}
@media(min-width:820px){.kp .k-savepill{display:inline-flex;align-items:center;gap:8px;padding:9px 12px;border-radius:999px;background:rgba(28,25,20,.06);border:1px solid var(--bd);font-weight:900;letter-spacing:.12em;text-transform:uppercase;font-size:11px}}
.kp .k-savepill .k-savepill__usd{color:var(--ok)}
.kp .k-countwrap{display:flex;align-items:center;gap:10px;flex-shrink:0}
.kp .k-countwrap__promo{display:flex;flex-direction:column;align-items:flex-start;gap:2px;min-width:0}
.kp .k-bogo{margin:0;font-size:11px;letter-spacing:.14em;text-transform:uppercase;font-weight:900;line-height:1.2}
.kp .k-easter-label{margin:0 0 2px;font-size:10px;letter-spacing:.18em;text-transform:uppercase;font-weight:900;color:var(--gd)}
.kp .k-countwrap .k-end{font-size:10px;letter-spacing:.12em;text-transform:uppercase;font-weight:900;color:var(--mu);text-align:center;max-width:200px}
.kp .k-mini{display:flex;align-items:center;gap:6px;font-size:12px;letter-spacing:.1em;font-weight:900;font-variant-numeric:tabular-nums;background:var(--wh);border:1px solid var(--bd);padding:9px 12px;border-radius:999px;white-space:nowrap}
.kp .k-mini .d{opacity:.45}
@media(max-width:819px){.kp .k-topbar__inner{flex-direction:column;height:auto;min-height:var(--top);padding:10px 16px 12px}.kp .k-offer{display:none}.kp .k-countwrap{flex-direction:column;align-items:center;width:100%}}
.kp .k-hero{background:var(--cr);padding:14px 0 48px}
.kp .k-grid{display:block}
@media(min-width:1024px){.kp .k-grid{display:grid;grid-template-columns:1.05fr .95fr;gap:56px;align-items:start}}
.kp .k-gal{margin-top:6px}
@media(min-width:1024px){.kp .k-gal{position:sticky;top:calc(var(--header-safe) + var(--top) + 18px)}}
.kp .k-main{position:relative;border-radius:var(--r);overflow:hidden;background:var(--sd);aspect-ratio:3/4;box-shadow:0 18px 55px rgba(28,25,20,.12)}
.kp .k-badge{position:absolute;top:14px;left:14px;z-index:4;background:rgba(28,25,20,.92);color:var(--gd);font-size:10px;letter-spacing:.14em;text-transform:uppercase;font-weight:900;padding:7px 12px;border-radius:999px}
.kp .k-slide{position:absolute;inset:0;opacity:0;transition:opacity .45s ease}
.kp .k-slide.on{opacity:1}
.kp .k-slide img,.kp .k-slide video{width:100%;height:100%;object-fit:cover}
.kp .k-thumbs{display:flex;gap:10px;margin-top:12px;overflow-x:auto;scrollbar-width:none}
.kp .k-thumbs::-webkit-scrollbar{display:none}
.kp .k-thumb{flex-shrink:0;width:74px;height:92px;border-radius:14px;overflow:hidden;border:2px solid transparent;background:var(--sd);cursor:pointer;transition:transform var(--tr),border-color var(--tr);position:relative}
.kp .k-thumb.on{border-color:var(--dp)}
.kp .k-thumb img{width:100%;height:100%;object-fit:cover}
.kp .k-tag{position:absolute;left:8px;bottom:8px;font-size:10px;letter-spacing:.12em;text-transform:uppercase;font-weight:900;color:var(--iv);background:rgba(28,25,20,.78);padding:4px 7px;border-radius:999px}
.kp .k-eye{font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--wr);font-weight:900;margin:14px 0 8px}
.kp .k-rating{margin:0 0 14px}
.kp .k-rating__row{display:flex;align-items:center;flex-wrap:wrap;gap:8px 10px}
.kp .k-rating__stars{color:var(--gd);font-size:14px;letter-spacing:1px;line-height:1;flex-shrink:0}
.kp .k-rating__score{font-size:14px;font-weight:900;color:var(--dp);letter-spacing:.02em}
.kp .k-rating__sep{color:var(--st);font-weight:700;opacity:.85}
.kp .k-rating__proof{font-size:13px;font-weight:800;color:var(--ch);letter-spacing:.01em}
.kp .k-rating__hint{margin:6px 0 0;font-size:11px;color:var(--mu);line-height:1.45;max-width:42ch}
.kp .k-social-micro{margin-top:10px;margin-bottom:8px;padding-bottom:10px;border-bottom:1px solid rgba(28,25,20,.06)}
.kp .k-social-micro__head{display:flex;align-items:center;gap:6px;margin:0 0 4px}
.kp .k-social-micro__ig{width:12px;height:12px;opacity:.72;flex-shrink:0}
.kp .k-social-micro__label{font-size:9px;letter-spacing:.16em;text-transform:uppercase;font-weight:900;color:var(--wr);margin:0}
.kp .k-social-micro__tag{margin:0 0 8px;font-size:10px;color:var(--mu);line-height:1.4;max-width:48ch}
.kp .k-sgrid--micro{display:flex;flex-direction:row;flex-wrap:nowrap;gap:8px;margin:0;overflow-x:auto;overflow-y:hidden;-webkit-overflow-scrolling:touch;scroll-snap-type:x mandatory;padding:2px 0 6px;scrollbar-width:thin}
.kp .k-sgrid--micro::-webkit-scrollbar{height:5px}
.kp .k-sgrid--micro::-webkit-scrollbar-thumb{background:rgba(28,25,20,.18);border-radius:999px}
.kp .k-scard--micro{position:relative;flex:0 0 104px;width:104px;scroll-snap-align:start;border-radius:12px;overflow:hidden;background:var(--sd);aspect-ratio:4/5;box-shadow:0 6px 18px rgba(28,25,20,.08)}
.kp .k-scard--micro img{width:100%;height:100%;object-fit:cover;display:block}
.kp .k-sov--micro{position:absolute;inset:0;background:linear-gradient(to top,rgba(28,25,20,.58),transparent 52%);display:flex;align-items:flex-end;padding:6px 6px 7px}
.kp .k-sov--micro span{color:var(--iv);font-weight:900;letter-spacing:.1em;text-transform:uppercase;font-size:8px;line-height:1.2}
.kp .k-title{font-size:clamp(26px,4.2vw,42px);line-height:1.08;margin:0 0 10px}
.kp .k-sub{color:var(--mu);font-size:14px;line-height:1.7;margin:0 0 16px;max-width:58ch}
.kp .k-pill{display:inline-flex;align-items:center;gap:10px;padding:10px 14px;border-radius:999px;background:rgba(28,25,20,.92);color:var(--gd);font-size:11px;letter-spacing:.14em;text-transform:uppercase;font-weight:900;margin:0 0 12px}
.kp .k-price{display:flex;align-items:baseline;gap:12px;flex-wrap:wrap;margin:8px 0 6px}
.kp .k-now{font-size:32px;letter-spacing:.02em}
.kp .k-was{font-size:16px;color:var(--st);text-decoration:line-through}
.kp .k-save{font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--ok);font-weight:900}
.kp .k-ship{display:flex;flex-wrap:wrap;gap:10px;margin:10px 0 14px}
.kp .k-chip{display:flex;align-items:center;gap:8px;font-size:12px;color:var(--ch);background:rgba(255,255,255,.55);border:1px solid rgba(28,25,20,.06);padding:8px 10px;border-radius:999px}
.kp .k-chip i{font-style:normal;color:var(--ok);font-weight:900}
.kp .k-paywrap{display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;margin:8px 0 14px}
.kp .k-pay{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
.kp .k-pay img{height:22px;width:auto;opacity:.85}
.kp .k-shiplogo{display:flex;align-items:center;gap:10px}
.kp .k-shiplogo img{height:22px;opacity:.8}
.kp .k-qty{display:flex;align-items:center;justify-content:space-between;gap:12px;margin:10px 0 12px}
.kp .k-ql{font-size:12px;color:var(--mu);letter-spacing:.12em;text-transform:uppercase;font-weight:900}
.kp .k-qc{display:flex;align-items:center;gap:8px;background:var(--wh);border:1px solid var(--bd);border-radius:999px;padding:6px}
.kp .k-qb{width:34px;height:34px;border:none;border-radius:999px;background:rgba(28,25,20,.06);cursor:pointer;font-weight:900}
.kp .k-qv{min-width:34px;text-align:center;font-variant-numeric:tabular-nums;font-weight:900}
.kp .k-pick{border:1px solid var(--bd);border-radius:18px;background:rgba(255,255,255,.65);padding:14px;margin:12px 0}
.kp .k-ph{display:flex;align-items:center;justify-content:space-between;gap:10px;margin-bottom:10px}
.kp .k-pt{font-size:12px;letter-spacing:.14em;text-transform:uppercase;font-weight:900;margin:0}
.kp .k-pr{font-size:11px;letter-spacing:.12em;text-transform:uppercase;font-weight:900;color:var(--gd);background:rgba(28,25,20,.92);padding:6px 10px;border-radius:999px}
.kp .k-sum{display:flex;align-items:center;gap:10px;background:rgba(255,255,255,.55);border:1px solid rgba(28,25,20,.06);padding:10px 12px;border-radius:16px;margin-bottom:10px}
.kp .k-sum__img{width:46px;height:58px;border-radius:12px;overflow:hidden;background:var(--sd);flex-shrink:0}
.kp .k-sum__img img{width:100%;height:100%;object-fit:cover}
.kp .k-sum__name{font-weight:900;font-size:13px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.kp .k-sum__var{font-size:12px;color:var(--mu);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.kp .k-ol{font-size:11px;letter-spacing:.12em;text-transform:uppercase;font-weight:900;color:var(--mu);margin:8px 0 6px}
.kp .k-or{display:flex;flex-wrap:wrap;gap:8px}
.kp .k-ob{border:1.5px solid var(--bd);background:var(--wh);color:var(--ch);padding:10px 12px;border-radius:14px;cursor:pointer;font-size:13px;font-weight:900;transition:all var(--tr)}
.kp .k-ob.on{background:var(--dp);border-color:var(--dp);color:var(--iv)}
.kp .k-ob.off{opacity:.35;cursor:not-allowed}
.kp .k-btn{width:100%;display:flex;align-items:center;justify-content:center;gap:10px;padding:16px 18px;border:none;border-radius:16px;cursor:pointer;font-size:13px;font-weight:900;letter-spacing:.14em;text-transform:uppercase;background:var(--dp);color:var(--iv);box-shadow:0 16px 40px rgba(28,25,20,.18);font-family:inherit}
.kp [data-k-add].kp-atc--busy{opacity:.55;pointer-events:none}
.kp .k-atc-wrap{margin-top:16px;margin-bottom:0}
.shopify-section .kp [data-k-add],.shopify-block .kp [data-k-add]{display:flex!important;visibility:visible!important;opacity:1!important}
.kp .k-sticky{position:fixed;left:0;right:0;bottom:0;z-index:9995;background:rgba(248,245,239,.97);backdrop-filter:blur(12px);border-top:1px solid var(--bd);padding:6px 0 calc(8px + env(safe-area-inset-bottom,0px));transform:translate3d(0,110%,0);transition:transform .32s;visibility:hidden;pointer-events:none}
.kp .k-sticky.k-sticky--on{transform:translate3d(0,0,0);visibility:visible;pointer-events:auto}
.kp.kp--sticky-bar{padding-bottom:calc(76px + env(safe-area-inset-bottom,0px))}
.kp .k-sticky__inner{max-width:1280px;margin:0 auto;padding:0 12px}
@media(min-width:1024px){.kp .k-sticky__inner{padding:0 48px}}
.kp .k-sticky__bar{display:flex;align-items:center;gap:8px}
.kp .k-sticky__hit{flex:1;min-width:0;display:flex;align-items:center;gap:10px;padding:6px 10px;border-radius:14px;border:1px solid var(--bd);background:rgba(255,255,255,.72);cursor:pointer;text-align:left;font:inherit}
.kp .k-sticky__thumb{width:40px;height:50px;border-radius:10px;object-fit:cover;flex-shrink:0;background:var(--sd)}
.kp .k-sticky__meta{flex:1;min-width:0;display:flex;flex-direction:column;gap:1px}
.kp .k-sticky__eyebrow{font-size:8px;letter-spacing:.14em;text-transform:uppercase;font-weight:900;color:var(--mu)}
.kp .k-sticky__sel{font-size:11px;font-weight:900;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.kp .k-sticky__chev{flex-shrink:0;width:22px;height:22px;border-radius:999px;border:1px solid var(--bd);display:flex;align-items:center;justify-content:center;font-size:9px;color:var(--mu)}
.kp .k-sticky__cta--bar{flex-shrink:0;min-width:92px;max-width:110px;padding:12px 10px!important;font-size:10px!important;letter-spacing:.1em!important;white-space:nowrap}
.kp .k-sticky-sheet{position:fixed;inset:0;z-index:9998;pointer-events:none}
.kp .k-sticky-sheet.k-sticky-sheet--on{pointer-events:auto}
.kp .k-sticky-sheet__backdrop{position:absolute;inset:0;background:rgba(28,25,20,.5);opacity:0;transition:opacity .28s}
.kp .k-sticky-sheet.k-sticky-sheet--on .k-sticky-sheet__backdrop{opacity:1}
.kp .k-sticky-sheet__panel{position:absolute;left:0;right:0;bottom:0;max-height:min(82dvh,560px);background:var(--wh);border-radius:20px 20px 0 0;transform:translate3d(0,105%,0);transition:transform .34s cubic-bezier(.25,.46,.45,.94);display:flex;flex-direction:column}
.kp .k-sticky-sheet.k-sticky-sheet--on .k-sticky-sheet__panel{transform:translate3d(0,0,0)}
.kp .k-sticky-sheet__head{display:flex;align-items:center;justify-content:space-between;padding:14px 16px 10px;border-bottom:1px solid rgba(28,25,20,.08)}
.kp .k-sticky-sheet__title{font-size:18px;margin:0}
.kp .k-sticky-sheet__x{width:38px;height:38px;border-radius:999px;border:1px solid var(--bd);background:rgba(28,25,20,.04);cursor:pointer;font-weight:900}
.kp .k-sticky-sheet__body{padding:12px 16px calc(16px + env(safe-area-inset-bottom,0px));overflow-y:auto;flex:1;min-height:0}
.kp .k-sticky-sheet__slot{display:flex;align-items:flex-start;gap:8px;margin-bottom:14px}
.kp .k-sticky-sheet__tag{flex-shrink:0;font-size:10px;letter-spacing:.14em;text-transform:uppercase;font-weight:900;color:var(--mu);padding-top:6px}
.kp .k-sticky-sheet__slot [data-k-picker-sticky]{flex:1;min-width:0}
.kp .k-micro{font-size:12px;color:var(--mu);margin:8px 0}
.kp .k-home-band{background:var(--iv);padding:52px 0}
.kp .k-home-band--alt{background:var(--cr);padding:60px 0}
.kp .k-home-intro{text-align:center;margin-bottom:26px}
.kp .k-home-intro .kh{display:block;font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--wr);font-weight:900;margin-bottom:8px}
.kp .k-home-intro .kt{font-size:clamp(22px,3.4vw,34px);line-height:1.12;margin:0 0 10px}
.kp .k-home-intro .ks{color:var(--mu);font-size:14px;line-height:1.7;max-width:56ch;margin:0 auto}
.kp .k-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-top:20px}
@media(max-width:760px){.kp .k-cards{grid-template-columns:1fr}}
.kp .k-card{position:relative;border-radius:20px;overflow:hidden;background:var(--sd);aspect-ratio:4/5;box-shadow:0 16px 48px rgba(28,25,20,.1)}
.kp .k-card img{width:100%;height:100%;object-fit:cover}
.kp .k-card .kv{position:absolute;inset:0;background:linear-gradient(to top,rgba(28,25,20,.58),transparent 52%);display:flex;align-items:flex-end;padding:14px}
.kp .k-card .kv span{color:var(--iv);font-weight:900;letter-spacing:.12em;text-transform:uppercase;font-size:11px}
.kp .k-mosaic{display:grid;gap:14px;grid-template-columns:1fr}
@media(min-width:900px){.kp .k-mosaic{grid-template-columns:1fr 1fr;gap:18px}}
.kp .k-mosaic .km{border-radius:20px;overflow:hidden;background:var(--sd);min-height:280px;box-shadow:0 16px 48px rgba(28,25,20,.08);position:relative}
@media(min-width:900px){.kp .k-mosaic .km{min-height:360px}}
.kp .k-mosaic .km img{width:100%;height:100%;object-fit:cover;display:block}
.kp .k-mosaic .km .ko{position:absolute;inset:0;background:linear-gradient(to top,rgba(28,25,20,.55),transparent 52%);display:flex;align-items:flex-end;padding:16px}
.kp .k-mosaic .km .ko span{color:var(--iv);font-weight:900;letter-spacing:.1em;text-transform:uppercase;font-size:11px}
</style>

