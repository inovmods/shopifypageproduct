  {
    "name": "Colors",
    "settings": [
      {
        "type": "paragraph",
        "content": "Customize your theme colors to match your brand identity."
      },
      {
        "type": "color",
        "id": "primary_color",
        "label": "Primary color",
        "default": "#000000"
      },
      {
        "type": "color",
        "id": "secondary_color",
        "label": "Secondary color",
        "default": "#ffffff"
      },
      {
        "type": "color",
        "id": "accent_color",
        "label": "Accent color",
        "default": "#ff0000"
      },
      {
        "type": "color",
        "id": "background_color",
        "label": "Background color",
        "default": "#ffffff"
      },
      {
        "type": "color",
        "id": "text_color",
        "label": "Text color",
        "default": "#000000"
      },
      {
        "type": "color",
        "id": "header_background",
        "label": "Header background",
        "default": "#ffffff"
      },
      {
        "type": "color",
        "id": "footer_background",
        "label": "Footer background",
        "default": "#000000"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "paragraph",
        "content": "Choose fonts that reflect your brand personality."
      },
      {
        "type": "font_picker",
        "id": "heading_font",
        "label": "Heading font",
        "default": "helvetica_neue_n4"
      },
      {
        "type": "font_picker",
        "id": "text_font",
        "label": "Body font",
        "default": "helvetica_neue_n4"
      },
      {
        "type": "range",
        "id": "heading_scale",
        "min": 100,
        "max": 150,
        "step": 5,
        "unit": "%",
        "label": "Heading scale",
        "default": 120
      },
      {
        "type": "range",
        "id": "body_scale",
        "min": 100,
        "max": 120,
        "step": 5,
        "unit": "%",
        "label": "Body font scale",
        "default": 100
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "paragraph",
        "content": "Control the overall layout and spacing of your theme."
      },
      {
        "type": "range",
        "id": "page_width",
        "min": 1200,
        "max": 1800,
        "step": 50,
        "unit": "px",
        "label": "Page width",
        "default": 1400
      },
      {
        "type": "select",
        "id": "section_spacing",
        "label": "Section spacing",
        "options": [
          {
            "value": "small",
            "label": "Small"
          },
          {
            "value": "medium",
            "label": "Medium"
          },
          {
            "value": "large",
            "label": "Large"
          }
        ],
        "default": "medium"
      },
      {
        "type": "checkbox",
        "id": "show_page_transition",
        "label": "Enable page transitions",
        "default": true
      }
    ]
  },
  {
    "name": "Header",
    "settings": [
      {
        "type": "paragraph",
        "content": "Configure your header appearance and behavior."
      },
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo image"
      },
      {
        "type": "range",
        "id": "logo_width",
        "min": 50,
        "max": 300,
        "step": 10,
        "unit": "px",
        "label": "Logo width",
        "default": 150
      },
      {
        "type": "checkbox",
        "id": "sticky_header",
        "label": "Sticky header",
        "default": true
      },
      {
        "type": "select",
        "id": "header_style",
        "label": "Header style",
        "options": [
          {
            "value": "minimal",
            "label": "Minimal"
          },
          {
            "value": "classic",
            "label": "Classic"
          },
          {
            "value": "modern",
            "label": "Modern"
          }
        ],
        "default": "modern"
      }
    ]
  },
  {
    "name": "3D Features",
    "settings": [
      {
        "type": "paragraph",
        "content": "Configure 3D model integration and animations."
      },
      {
        "type": "url",
        "id": "spline_3d_url",
        "label": "Spline 3D model URL",
